@model IEnumerable<PizzaDeli.Models.Category>
@{
    ViewData["Title"] = "Quản lý danh mục";
    Layout = "_AdminLayout";
    var currentStatus = ViewBag.CurrentStatus as string ?? "all";
    var searchQuery = ViewBag.SearchQuery as string ?? "";
}

<div class="page-header">
    <div class="ph-titles">
        <h2>Quản lý danh mục</h2>
        <p>Quản lý các nhóm sản phẩm trong hệ thống</p>
    </div>
    <div class="ph-actions">
        <a asp-action="CategoryCreate" class="btn-pill primary add-btn">
            <span class="material-symbols-outlined">add_circle</span>
            Thêm danh mục mới
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div style="background: #dcfce7; color: #16a34a; padding: 1rem; border-radius: 8px; margin-bottom: 1rem; font-weight: 600; font-size: 0.875rem;">
        <span class="material-symbols-outlined" style="vertical-align: middle; font-size: 1.125rem; margin-right: 0.5rem;">check_circle</span>
        @TempData["SuccessMessage"]
    </div>
}

<div class="product-list-container">

    <!-- Toolbar: Search + Filter tabs -->
    <div class="pl-toolbar" style="justify-content: space-between; flex-wrap: wrap; gap: 10px;">
        <form method="get" asp-action="Categories" class="pl-search" style="max-width: 400px;">
            <span class="material-symbols-outlined search-icon">search</span>
            <input type="text" name="searchQuery" value="@searchQuery"
                   placeholder="Tìm kiếm theo tên sản phẩm hoặc mã..."
                   onchange="this.form.submit()" />
            <input type="hidden" name="status" value="@currentStatus" />
        </form>

        <div class="pl-tabs">
            <a href="@Url.Action("Categories", new { status = "all", searchQuery })"
               class="pl-tab @(currentStatus == "all" ? "active" : "")"
               style="text-decoration: none;">Tất cả</a>
            <a href="@Url.Action("Categories", new { status = "active", searchQuery })"
               class="pl-tab @(currentStatus == "active" ? "active" : "")"
               style="text-decoration: none;">Active</a>
            <a href="@Url.Action("Categories", new { status = "inactive", searchQuery })"
               class="pl-tab @(currentStatus == "inactive" ? "active" : "")"
               style="text-decoration: none;">Inactive</a>
        </div>
    </div>

    <!-- Category Table -->
    <div class="table-responsive">
        <table class="pl-table" style="min-width: 700px;">
            <thead>
                <tr>
                    <th style="width: 80px;">HÌNH ẢNH</th>
                    <th style="width: 22%;">TÊN DANH MỤC</th>
                    <th>MÔ TẢ</th>
                    <th style="width: 14%; text-align: center;">TRẠNG THÁI</th>
                    <th style="width: 10%; text-align: right;">HÀNH ĐỘNG</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div style="width: 2.75rem; height: 2.75rem; border-radius: 50%; background: #f5f0ec; display: flex; align-items: center; justify-content: center; color: #5C3D2E; border: 1px solid #ede8e3;">
                                <span class="material-symbols-outlined" style="font-size: 1.125rem;">local_pizza</span>
                            </div>
                        </td>
                        <td>
                            <div style="font-size: 0.9375rem; font-weight: 700; color: #111; margin-bottom: 3px;">@item.Name</div>
                            <div style="font-size: 0.75rem; color: #9ca3af;">@(item.Products?.Count ?? 0) sản phẩm</div>
                        </td>
                        <td>
                            <div style="font-size: 0.8125rem; color: #6b7280; line-height: 1.5; max-width: 420px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                @(string.IsNullOrEmpty(item.Description) ? "Chưa có mô tả." : item.Description)
                            </div>
                        </td>
                        <td style="text-align: center;">
                            @if (item.IsActive)
                            {
                                <span style="display: inline-block; padding: 0.3rem 0.875rem; border-radius: 99px; font-size: 0.75rem; font-weight: 700; background: #dcfce7; color: #16a34a;">Active</span>
                            }
                            else
                            {
                                <span style="display: inline-block; padding: 0.3rem 0.875rem; border-radius: 99px; font-size: 0.75rem; font-weight: 700; background: #f3f4f6; color: #9ca3af;">Inactive</span>
                            }
                        </td>
                        <td style="text-align: right;">
                            <div class="pt-actions" style="justify-content: flex-end;">
                                <a asp-action="CategoryEdit" asp-route-id="@item.Id"
                                   class="action-btn edit" title="Sửa"
                                   style="background: none; border: none; color: #9ca3af; padding: 0.375rem; cursor: pointer; border-radius: 6px; display: inline-flex; align-items: center; transition: color .2s;">
                                    <span class="material-symbols-outlined" style="font-size: 1.125rem;">edit</span>
                                </a>
                                <form asp-action="CategoryDelete" asp-route-id="@item.Id" method="post"
                                      style="display:inline;"
                                      onsubmit="return confirm('Bạn có chắc chắn muốn xóa danh mục này?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="action-btn delete" title="Xóa"
                                            style="background: none; border: none; color: #9ca3af; padding: 0.375rem; cursor: pointer; border-radius: 6px; display: inline-flex; align-items: center; transition: color .2s;">
                                        <span class="material-symbols-outlined" style="font-size: 1.125rem;">delete</span>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }

                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" style="text-align: center; color: #9ca3af; padding: 3rem; font-size: 0.9375rem;">
                            <span class="material-symbols-outlined" style="font-size: 2.5rem; display: block; margin-bottom: 0.5rem; opacity: .4;">category</span>
                            Chưa có danh mục nào.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination – nằm cuối card, text trái · buttons phải -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 1.5rem; padding-top: 1.25rem; border-top: 1px solid #f3f4f6;">
        <div style="font-size: 0.8125rem; color: #6b7280;">
            Hiển thị <strong style="color:#111;">1–@(Model.Count())</strong> trong số <strong style="color:#111;">@Model.Count()</strong> danh mục
        </div>
        <div class="pl-pagination">
            <button class="page-btn" disabled><span class="material-symbols-outlined">chevron_left</span></button>
            <button class="page-btn active">1</button>
            <button class="page-btn" disabled><span class="material-symbols-outlined">chevron_right</span></button>
        </div>
    </div>

</div>
