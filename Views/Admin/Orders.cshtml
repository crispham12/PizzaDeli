@model IEnumerable<PizzaDeli.Models.Order>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
    Layout = "_AdminLayout";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int totalOrders = ViewBag.TotalOrders ?? 0;
    var currentStatus = ViewBag.CurrentStatus as string ?? "all";
    var searchQuery = ViewBag.SearchQuery as string ?? "";

    // Hàm lấy initials từ tên
    string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][0].ToString().ToUpper();
        return (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpper();
    }

    // Màu avatar theo tên
    string[] avatarColors = { "#f59e0b", "#10b981", "#3b82f6", "#8b5cf6", "#ef4444", "#ec4899", "#14b8a6" };
    string GetAvatarColor(string? name)
    {
        if (string.IsNullOrEmpty(name)) return avatarColors[0];
        return avatarColors[Math.Abs(name.GetHashCode()) % avatarColors.Length];
    }

    // Nhãn & màu trạng thái
    (string label, string bg, string color) GetStatus(string status) => status switch
    {
        "Pending"    => ("Chờ xử lý",    "#fef3c7", "#d97706"),
        "Processing" => ("Đang chế biến","#dbeafe",  "#2563eb"),
        "Delivering" => ("Đang giao",    "#dcfce7",  "#16a34a"),
        "Completed"  => ("Hoàn thành",   "#f0fdf4",  "#15803d"),
        "Cancelled"  => ("Đã hủy",       "#fee2e2",  "#dc2626"),
        _            => (status,          "#f3f4f6",  "#6b7280")
    };
}

<!-- Page Header -->
<div class="page-header">
    <div class="ph-titles">
        <h2>Quản lý đơn hàng</h2>
        <p>Xem danh sách và theo dõi trạng thái đơn hàng từ khách hàng</p>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div style="background:#dcfce7;color:#16a34a;padding:1rem;border-radius:8px;margin-bottom:1rem;font-weight:600;font-size:.875rem;">
        <span class="material-symbols-outlined" style="vertical-align:middle;font-size:1.125rem;margin-right:.5rem;">check_circle</span>
        @TempData["SuccessMessage"]
    </div>
}

<div class="product-list-container">

    <!-- Toolbar: Search + Status tabs -->
    <div class="ord-toolbar">
        <form method="get" asp-action="Orders" class="pl-search ord-search">
            <span class="material-symbols-outlined search-icon">search</span>
            <input type="text" name="searchQuery" value="@searchQuery"
                   placeholder="Tìm kiếm theo mã đơn hoặc tên khách hàng..."
                   onchange="this.form.submit()" />
            <input type="hidden" name="status" value="@currentStatus" />
        </form>

        <div class="ord-status-tabs">
            @{
                var tabs = new[]
                {
                    ("all", "Tất cả"),
                    ("Pending", "Chờ xử lý"),
                    ("Processing", "Đang chế biến"),
                    ("Delivering", "Đang giao"),
                    ("Cancelled", "Đã hủy"),
                };
            }
            @foreach (var (val, label) in tabs)
            {
                <a href="@Url.Action("Orders", new { status = val, searchQuery })"
                   class="ord-status-tab @(currentStatus == val ? "active" : "")"
                   style="text-decoration:none;">@label</a>
            }
        </div>
    </div>

    <!-- Orders Table -->
    <div class="table-responsive">
        <table class="pl-table ord-table">
            <thead>
                <tr>
                    <th>MÃ ĐƠN</th>
                    <th>KHÁCH HÀNG</th>
                    <th>NGÀY ĐẶT</th>
                    <th>TỔNG TIỀN</th>
                    <th style="text-align:center;">TRẠNG THÁI</th>
                    <th style="text-align:right;">HÀNH ĐỘNG</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    var (statusLabel, statusBg, statusColor) = GetStatus(order.Status);
                    var initials = GetInitials(order.User?.FullName);
                    var avatarBg = GetAvatarColor(order.User?.FullName);
                    var ordCode = "#ORD-" + order.Id.Substring(0, 4).ToUpper();

                    <tr>
                        <td>
                            <span class="ord-id">@ordCode</span>
                        </td>
                        <td>
                            <div class="ord-customer">
                                <div class="ord-avatar" style="background:@avatarBg;">@initials</div>
                                <span class="ord-name">@(order.User?.FullName ?? "Khách")</span>
                            </div>
                        </td>
                        <td>
                            <span class="ord-date">@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
                        </td>
                        <td>
                            <span class="ord-total">@order.FinalAmount.ToString("N0")đ</span>
                        </td>
                        <td style="text-align:center;">
                            <span class="ord-badge" style="background:@statusBg;color:@statusColor;">@statusLabel</span>
                        </td>
                        <td style="text-align:right;">
                            <div style="display:flex; align-items:center; justify-content:flex-end; gap:0.5rem;">
                                @if (order.Status != "Completed" && order.Status != "Cancelled")
                                {
                                    <form method="post" asp-action="OrderUpdateStatus" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@order.Id" />
                                        @{
                                            var nextStatus = order.Status switch {
                                                "Pending"    => "Processing",
                                                "Processing" => "Delivering",
                                                "Delivering" => "Completed",
                                                _ => ""
                                            };
                                            var nextLabel = nextStatus switch {
                                                "Processing" => "Xác nhận",
                                                "Delivering" => "Giao hàng",
                                                "Completed"  => "Hoàn thành",
                                                _ => ""
                                            };
                                        }
                                        @if (!string.IsNullOrEmpty(nextStatus))
                                        {
                                            <input type="hidden" name="status" value="@nextStatus" />
                                            <button type="submit" title="@nextLabel"
                                                    style="background:#5c433b;color:#fff;border:none;border-radius:6px;padding:0.35rem 0.75rem;font-size:0.8rem;font-weight:600;cursor:pointer;">
                                                @nextLabel
                                            </button>
                                        }
                                    </form>
                                    @if (order.Status == "Pending")
                                    {
                                        <form method="post" asp-action="OrderUpdateStatus" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@order.Id" />
                                            <input type="hidden" name="status" value="Cancelled" />
                                            <button type="submit" title="Hủy đơn"
                                                    style="background:#fee2e2;color:#dc2626;border:none;border-radius:6px;padding:0.35rem 0.75rem;font-size:0.8rem;font-weight:600;cursor:pointer;"
                                                    onclick="return confirm('Hủy đơn hàng này?')">
                                                Hủy
                                            </button>
                                        </form>
                                    }
                                }
                            </div>
                        </td>
                    </tr>
                }

                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" style="text-align:center;color:#9ca3af;padding:3rem;font-size:.9375rem;">
                            <span class="material-symbols-outlined" style="font-size:2.5rem;display:block;margin-bottom:.5rem;opacity:.4;">receipt_long</span>
                            Chưa có đơn hàng nào.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="ord-footer">
        <div class="ord-info">
            Hiển thị <strong>@((currentPage - 1) * 10 + 1)–@((currentPage - 1) * 10 + Model.Count())</strong>
            của <strong>@totalOrders</strong> đơn hàng
        </div>
        <div class="pl-pagination">
            @if (currentPage > 1)
            {
                <a href="@Url.Action("Orders", new { page = currentPage - 1, searchQuery, status = currentStatus })" class="page-btn">
                    <span class="material-symbols-outlined">chevron_left</span>
                </a>
            }
            else
            {
                <button class="page-btn" disabled><span class="material-symbols-outlined">chevron_left</span></button>
            }

            @for (int i = 1; i <= totalPages; i++)
            {
                if (i == 1 || i == totalPages || Math.Abs(i - currentPage) <= 1)
                {
                    <a href="@Url.Action("Orders", new { page = i, searchQuery, status = currentStatus })"
                       class="page-btn @(i == currentPage ? "active" : "")">@i</a>
                }
                else if (Math.Abs(i - currentPage) == 2)
                {
                    <span class="page-dots">...</span>
                }
            }

            @if (currentPage < totalPages)
            {
                <a href="@Url.Action("Orders", new { page = currentPage + 1, searchQuery, status = currentStatus })" class="page-btn">
                    <span class="material-symbols-outlined">chevron_right</span>
                </a>
            }
            else
            {
                <button class="page-btn" disabled><span class="material-symbols-outlined">chevron_right</span></button>
            }
        </div>
    </div>
</div>
