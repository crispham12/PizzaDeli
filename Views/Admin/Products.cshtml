@model IEnumerable<PizzaDeli.Models.Product>
@{
    ViewData["Title"] = "Quản lý sản phẩm";
    Layout = "_AdminLayout";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    var categories = ViewBag.Categories as List<PizzaDeli.Models.Category> ?? new List<PizzaDeli.Models.Category>();
}

<div class="page-header">
    <div class="ph-titles">
        <h2>Sản phẩm của chúng tôi</h2>
        <p>Danh sách thực đơn hiện tại trong hệ thống.</p>
    </div>
    <div class="ph-actions">
        <!-- Nút Đồng bộ AI Vector -->
        <button id="btnSyncAi" class="btn-pill" style="background:#1e40af; color:#fff; border:none; gap:0.4rem;"
                onclick="doSyncEmbeddings()" title="Đồng bộ AI vector cho sản phẩm chưa có embedding">
            <span class="material-symbols-outlined" id="syncIcon">auto_awesome</span>
            Đồng bộ AI
        </button>
        <a asp-action="ProductCreate" class="btn-pill primary add-btn">
            <span class="material-symbols-outlined">add_circle</span>
            Thêm sản phẩm mới
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div style="background: #dcfce7; color: #16a34a; padding: 1rem; border-radius: 8px; margin-bottom: 1rem;">
        @TempData["SuccessMessage"]
    </div>
}
@if (TempData["AiWarning"] != null)
{
    <div style="background: #fef9c3; color: #854d0e; padding: 1rem; border-radius: 8px; margin-bottom: 1rem; display:flex; align-items:center; gap:0.5rem;">
        <span class="material-symbols-outlined" style="font-size:1.2rem;">warning</span>
        @TempData["AiWarning"]
    </div>
}

<!-- Modal kết quả Sync AI -->
<div id="syncModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.45); z-index:9999; align-items:center; justify-content:center;">
    <div style="background:#fff; border-radius:16px; padding:2rem; max-width:480px; width:90%; box-shadow:0 20px 60px rgba(0,0,0,0.2);">
        <div style="display:flex; align-items:center; gap:0.75rem; margin-bottom:1rem;">
            <span class="material-symbols-outlined" style="color:#1e40af; font-size:1.6rem;">smart_toy</span>
            <h3 style="margin:0; font-size:1.1rem; color:#111827;">Kết quả Đồng bộ AI</h3>
        </div>
        <div id="syncResult" style="font-size:0.95rem; color:#374151;"></div>
        <div style="text-align:right; margin-top:1.5rem;">
            <button onclick="document.getElementById('syncModal').style.display='none'"
                    style="padding:0.5rem 1.5rem; border-radius:8px; border:none; background:#5c3d2e; color:#fff; font-weight:700; cursor:pointer;">
                Đóng
            </button>
        </div>
    </div>
</div>

<div class="product-list-container">
    <!-- Toolbar: Search & Filter -->
    <div class="pl-toolbar">
        <form method="get" asp-action="Products" class="pl-search">
            <span class="material-symbols-outlined search-icon">search</span>
            <input type="text" name="searchQuery" value="@ViewBag.SearchQuery" placeholder="Tìm kiếm theo tên sản phẩm hoặc mã..." onchange="this.form.submit()" />
        </form>
        
        <div class="pl-tabs-wrapper">
            <div class="pl-tabs">
                <a href="@Url.Action("Products")" class="pl-tab @(ViewBag.CurrentCategory == null ? "active" : "")">Tất cả</a>
                @foreach(var cat in categories.Take(4))
                {
                    <a href="@Url.Action("Products", new { categoryId = cat.Id })" class="pl-tab @(ViewBag.CurrentCategory == cat.Id ? "active" : "")">@cat.Name</a>
                }
                @if (categories.Count > 4)
                {
                    <button class="pl-tab pl-tab-more" id="plTabMoreBtn" onclick="toggleCatDropdown()" title="Xem thêm">
                        <span class="material-symbols-outlined" id="plTabMoreIcon">keyboard_arrow_down</span>
                    </button>
                }
            </div>

            @if (categories.Count > 4)
            {
                <div class="pl-tabs-dropdown" id="plTabsDropdown">
                    <div class="pl-tabs-dropdown-grid">
                        @foreach(var cat in categories.Skip(4))
                        {
                            <a href="@Url.Action("Products", new { categoryId = cat.Id })" class="pl-tab-dropdown-item @(ViewBag.CurrentCategory == cat.Id ? "active" : "")">@cat.Name</a>
                        }
                    </div>
                </div>
            }
        </div>
        
        <button class="pl-filter-btn">
            <span class="material-symbols-outlined">filter_list</span> Lọc nâng cao
        </button>
    </div>

    <!-- Product Table -->
    <div class="table-responsive">
        <table class="pl-table">
            <thead>
                <tr>
                    <th>HÌNH ẢNH</th>
                    <th>TÊN SẢN PHẨM</th>
                    <th>DANH MỤC</th>
                    <th>GIÁ TIỀN</th>
                    <th>TRẠNG THÁI</th>
                    <th class="text-right">HÀNH ĐỘNG</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="pt-img" style="background-image: url('@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/placeholder.jpg" : item.ImageUrl)');"></div>
                        </td>
                        <td>
                            <div class="pt-name">@item.Name</div>
                            <div class="pt-code">#@item.Id.Substring(0, 8).ToUpper()</div>
                            @if (!string.IsNullOrEmpty(item.ImageEmbedding))
                            {
                                <span title="Đã có AI vector" style="display:inline-flex;align-items:center;gap:2px;background:#dbeafe;color:#1e40af;font-size:0.7rem;font-weight:700;border-radius:4px;padding:1px 5px;margin-top:2px;">
                                    <span class="material-symbols-outlined" style="font-size:0.8rem;">auto_awesome</span> AI
                                </span>
                            }
                            else
                            {
                                <span title="Chưa có AI vector" style="display:inline-flex;align-items:center;gap:2px;background:#f3f4f6;color:#9ca3af;font-size:0.7rem;font-weight:700;border-radius:4px;padding:1px 5px;margin-top:2px;">
                                    <span class="material-symbols-outlined" style="font-size:0.8rem;">auto_awesome</span> Chưa sync
                                </span>
                            }
                        </td>
                        <td>
                            <!-- Fake color logic per category ID for demo -->
                            <span class="pt-cat @(item.CategoryId % 3 == 0 ? "cat-drinks" : item.CategoryId % 2 == 0 ? "cat-spaghetti" : "cat-pizza")">
                                @(item.Category?.Name ?? "KHÁC")
                            </span>
                        </td>
                        <td><span class="pt-price">@item.Price.ToString("N0")đ</span></td>
                        <td>
                            @if (item.IsAvailable)
                            {
                                <div class="pt-status status-in"><div class="dot green"></div> Còn hàng</div>
                            }
                            else
                            {
                                <div class="pt-status status-out"><div class="dot grey" style="background: #9ca3af;"></div> Hết hàng</div>
                            }
                        </td>
                        <td class="text-right">
                            <div class="pt-actions">
                                <a asp-action="ProductEdit" asp-route-id="@item.Id" class="action-btn edit" title="Sửa"><span class="material-symbols-outlined">edit</span></a>
                                <form asp-action="ProductDelete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Bạn có chắc chắn muốn xóa sản phẩm này?');">
                                    <button type="submit" class="action-btn delete" title="Xóa"><span class="material-symbols-outlined">delete</span></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                
                @if(!Model.Any())
                {
                    <tr>
                        <td colspan="6" style="text-align: center; color: #999; padding: 2rem;">Chưa có sản phẩm nào.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="pl-footer">
        <div class="pl-info">
            Hiển thị <strong>@(Model.Count())</strong> trong số <strong>@ViewBag.TotalProducts</strong> sản phẩm
        </div>
        <div class="pl-pagination">
            @if (currentPage > 1)
            {
                <a href="@Url.Action("Products", new { page = currentPage - 1, searchQuery = ViewBag.SearchQuery, categoryId = ViewBag.CurrentCategory })" class="page-btn"><span class="material-symbols-outlined">chevron_left</span></a>
            }
            
            @for (int i = 1; i <= totalPages; i++)
            {
                if (i == 1 || i == totalPages || Math.Abs(i - currentPage) <= 1)
                {
                     <a href="@Url.Action("Products", new { page = i, searchQuery = ViewBag.SearchQuery, categoryId = ViewBag.CurrentCategory })" class="page-btn @(i == currentPage ? "active" : "")">@i</a>
                }
                else if (Math.Abs(i - currentPage) == 2)
                {
                    <span class="page-dots">...</span>
                }
            }

            @if (currentPage < totalPages)
            {
                <a href="@Url.Action("Products", new { page = currentPage + 1, searchQuery = ViewBag.SearchQuery, categoryId = ViewBag.CurrentCategory })" class="page-btn"><span class="material-symbols-outlined">chevron_right</span></a>
            }
        </div>
    </div>
</div>

<script>
    function toggleCatDropdown() {
        var dropdown = document.getElementById('plTabsDropdown');
        var btn = document.getElementById('plTabMoreBtn');
        if (!dropdown) return;
        var isOpen = dropdown.classList.contains('open');
        if (isOpen) {
            dropdown.classList.remove('open');
            btn.classList.remove('open');
        } else {
            dropdown.classList.add('open');
            btn.classList.add('open');
        }
    }

    // Đóng dropdown khi click ra ngoài
    document.addEventListener('click', function (e) {
        var wrapper = document.querySelector('.pl-tabs-wrapper');
        var dropdown = document.getElementById('plTabsDropdown');
        var btn = document.getElementById('plTabMoreBtn');
        if (wrapper && dropdown && !wrapper.contains(e.target)) {
            dropdown.classList.remove('open');
            if (btn) btn.classList.remove('open');
        }
    });

    // ---- AI Sync Embeddings ----
    async function doSyncEmbeddings() {
        const btn = document.getElementById('btnSyncAi');
        const icon = document.getElementById('syncIcon');
        if (!btn) return;

        if (!confirm('Đồng bộ AI vector cho tất cả sản phẩm chưa có embedding?\n(Yêu cầu Python AI Service đang chạy tại localhost:8000)'))
            return;

        btn.disabled = true;
        btn.style.opacity = '0.7';
        icon.textContent = 'hourglass_top';
        icon.style.animation = 'spin 1s linear infinite';

        if (!document.getElementById('ai-spin-style')) {
            const s = document.createElement('style');
            s.id = 'ai-spin-style';
            s.innerHTML = '@@keyframes spin { 100% { transform: rotate(360deg); } }';
            document.head.appendChild(s);
        }

        try {
            const token = document.querySelector('meta[name="__RequestVerificationToken"]')?.content
                       || document.querySelector('input[name="__RequestVerificationToken"]')?.value
                       || '';

            const res = await fetch('/Admin/SyncEmbeddings', {
                method: 'POST',
                headers: { 'RequestVerificationToken': token, 'Content-Type': 'application/json' }
            });
            const json = await res.json();

            // Hiển thị kết quả qua modal
            const resultEl = document.getElementById('syncResult');
            let html = `<div style="padding:0.75rem; background:#f0fdf4; border-radius:8px; margin-bottom:1rem;">
                <b style="color:#16a34a;">✔️ Đồng bộ hoàn tất!</b><br/>
                <span style="color:#374151;">
                    ✅ Thành công: <b>${json.synced || 0}</b> &nbsp;|&nbsp;
                    ❌ Thất bại: <b>${json.failed || 0}</b> &nbsp;|&nbsp;
                    📦 Tổng cộng: <b>${json.total || 0}</b>
                </span>
            </div>`;
            if (json.errors && json.errors.length > 0) {
                html += `<div style="font-size:0.85rem;color:#6b7280;"><b>Chi tiết lỗi:</b><ul style="margin:0.5rem 0 0 1rem; padding:0;">`;
                json.errors.forEach(e => { html += `<li>${e}</li>`; });
                html += `</ul></div>`;
            }
            resultEl.innerHTML = html;
            document.getElementById('syncModal').style.display = 'flex';

            // Reload trang sau 2.5 giây nếu có sync thành công
            if (json.synced > 0) setTimeout(() => location.reload(), 2500);

        } catch (err) {
            alert('Đồng bộ thất bại. Kiểm tra AI Service (đầu tiên chạy run-ai.bat).\n' + err.message);
        } finally {
            btn.disabled = false;
            btn.style.opacity = '1';
            icon.textContent = 'auto_awesome';
            icon.style.animation = '';
        }
    }
</script>
