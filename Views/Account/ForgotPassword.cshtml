@{
    ViewData["Title"] = "Quên mật khẩu - PizzaDeli";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <style>
        body {
            background-color: #f9fafb;
            font-family: 'Plus Jakarta Sans', sans-serif;
            margin: 0;
            padding: 0;
        }
        
        .cp-container {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 4rem 1rem;
            min-height: 100vh;
        }

        .cp-card {
            background: #ffffff;
            width: 100%;
            max-width: 540px;
            border-radius: 20px;
            padding: 3rem 3.5rem;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.04);
        }

        .cp-card h2 {
            font-size: 1.875rem;
            font-weight: 800;
            color: #111827;
            margin-top: 0;
            margin-bottom: 0.5rem;
            text-align: center;
        }

        .cp-subtitle {
            font-size: 0.9375rem;
            color: #6b7280;
            margin-bottom: 2rem;
            line-height: 1.5;
            text-align: center;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        label {
            display: block;
            font-size: 0.875rem;
            font-weight: 700;
            color: #374151;
            margin-bottom: 0.5rem;
        }

        .input-wrapper {
            position: relative;
        }

        .cp-input {
            width: 100%;
            Box-sizing: border-box;
            padding: 0.875rem 1rem;
            font-size: 0.9375rem;
            color: #111827;
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 9999px;
            transition: all 0.2s;
            font-family: inherit;
        }

        .cp-input:focus {
            outline: none;
            border-color: #5c3d2e;
            box-shadow: 0 0 0 3px rgba(92, 61, 46, 0.1);
        }

        .cp-input:disabled {
            background-color: #f9fafb;
            color: #9ca3af;
            cursor: not-allowed;
        }

        .btn-eye {
            position: absolute;
            right: 1.25rem;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: #9ca3af;
            cursor: pointer;
            display: flex;
            align-items: center;
            padding: 0;
        }

        .btn-eye:hover {
            color: #4b5563;
        }

        /* OTP Section */
        .otp-section {
            background: #fdfaf8;
            border-radius: 16px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            border: 1px solid #f3e8e4;
        }

        .opt-desc {
            font-size: 0.8125rem;
            color: #94a3b8;
            margin-top: 0;
            margin-bottom: 1rem;
        }

        .otp-input-group {
            display: flex;
            gap: 1rem;
            align-items: center;
        }

        .otp-letters {
            letter-spacing: 0.4em;
            text-align: center;
            font-size: 1.1rem;
            font-weight: 700;
            flex: 1;
        }

        .btn-send-code {
            background: #5c3d2e;
            color: #fff;
            border: none;
            border-radius: 9999px;
            padding: 0.875rem 1.5rem;
            font-weight: 600;
            font-size: 0.875rem;
            cursor: pointer;
            transition: 0.2s;
            white-space: nowrap;
        }

        .btn-send-code:hover {
            background: #4a3125;
        }

        .btn-send-code:disabled {
            background: #d1d5db;
            cursor: not-allowed;
            color: #6b7280;
        }

        .resend-wrapper {
            margin-top: 0.75rem;
            font-size: 0.8125rem;
        }

        .resend-link {
            color: #5c3d2e;
            font-weight: 600;
            text-decoration: none;
        }

        .resend-link:hover {
            text-decoration: underline;
        }

        .note-text {
            font-size: 0.75rem;
            color: #9ca3af;
            margin-top: 0.5rem;
        }

        .btn-submit {
            width: 100%;
            background: #5c3d2e;
            color: #fff;
            border: none;
            border-radius: 9999px;
            padding: 1rem;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            margin-top: 1rem;
            transition: 0.2s;
        }

        .btn-submit:hover:not(:disabled) {
            background: #4a3125;
            transform: translateY(-1px);
        }
        
        .btn-submit:disabled {
            background: #d1d5db;
            color: #9ca3af;
            cursor: not-allowed;
        }

        .btn-cancel {
            display: inline-block;
            color: #6b7280;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.875rem;
            margin-top: 1.5rem;
            transition: color 0.2s;
        }

        .btn-cancel:hover {
            color: #111827;
        }

        /* Nav Logo */
        .auth-nav-logo {
            position: absolute;
            top: 2rem;
            left: 2rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            color: #5d4037;
            font-weight: 800;
            font-size: 1.5rem;
            text-decoration: none;
            letter-spacing: -0.02em;
        }
        .auth-nav-logo .material-symbols-outlined {
            font-size: 2rem;
        }
    </style>
</head>
<body>

    <a asp-controller="Home" asp-action="Index" class="auth-nav-logo">
        <span class="material-symbols-outlined">local_pizza</span>
        <span>PizzaDeli</span>
    </a>

    <div class="cp-container">
        <div class="cp-card">
            <h2>Quên mật khẩu</h2>
            <p class="cp-subtitle">Vui lòng nhập email đăng nhập để lấy lại mật khẩu của bạn.</p>

            @if (TempData["Error"] != null)
            {
                <div style="background:#fee2e2;color:#ef4444;padding:1rem;border-radius:12px;margin-bottom:1.5rem;font-weight:500;font-size:0.875rem;">
                    <span class="material-symbols-outlined" style="vertical-align:bottom;font-size:1.1rem;margin-right:0.25rem;">error</span>
                    @TempData["Error"]
                </div>
            }

            <form id="forgotPasswordForm" method="post" asp-action="ResetPassword" asp-controller="Account">
                @Html.AntiForgeryToken()

                <!-- Email Input -->
                <div class="form-group">
                    <label>Địa chỉ Email</label>
                    <div class="input-wrapper">
                        <input type="email" id="userEmail" name="email" class="cp-input" placeholder="Nhập email của bạn" required />
                    </div>
                </div>

                <!-- OTP Section -->
                <div class="otp-section">
                    <label>Mã xác nhận email</label>
                    <p class="opt-desc">Mã OTP sẽ được gửi đến email của bạn để xác thực khối phục.</p>
                    <div class="otp-input-group">
                        <input type="text" id="otpCode" name="code" class="cp-input otp-letters" placeholder="0 0 0 0 0 0" maxlength="6" autocomplete="off" oninput="formatOtp(this)" disabled />
                        <button type="button" id="btnSendCode" class="btn-send-code" onclick="sendOtp()">Gửi mã</button>
                    </div>
                    <div class="resend-wrapper" id="resendWrapper" style="display:none;">
                        <span id="countdownText" style="color: #6b7280;">Gửi lại mã sau <span id="countdown">60</span>s</span>
                        <a href="javascript:void(0)" id="btnResend" class="resend-link" style="display:none;" onclick="sendOtp()">Gửi lại mã</a>
                    </div>
                    <div id="otpMessage" style="font-size: 0.8125rem; margin-top: 0.5rem; font-weight: 500;"></div>
                </div>

                <!-- New Password Section -->
                <div class="form-group">
                    <label>Mật khẩu mới</label>
                    <div class="input-wrapper">
                        <input type="password" id="newPassword" name="newPassword" class="cp-input" placeholder="Nhập mật khẩu mới" disabled required />
                        <button type="button" class="btn-eye" onclick="togglePass('newPassword', this)" tabindex="-1">
                            <span class="material-symbols-outlined">visibility</span>
                        </button>
                    </div>
                    <div class="note-text">Tối thiểu 6 ký tự.</div>
                </div>

                <div class="form-group">
                    <label>Xác nhận mật khẩu mới</label>
                    <div class="input-wrapper">
                        <input type="password" id="confirmPassword" class="cp-input" placeholder="Nhập lại mật khẩu mới" disabled required />
                        <button type="button" class="btn-eye" onclick="togglePass('confirmPassword', this)" tabindex="-1">
                            <span class="material-symbols-outlined">visibility</span>
                        </button>
                    </div>
                </div>

                <!-- Actions -->
                <button type="button" id="btnSubmit" class="btn-submit" onclick="submitForm()" disabled>Xác nhận đặt lại</button>
                <div style="text-align:center;">
                    <a asp-controller="Account" asp-action="Login" class="btn-cancel">Quay lại đăng nhập</a>
                </div>
            </form>
        </div>
    </div>

    <script>
        let countdownInt = null;

        function togglePass(inputId, btn) {
            const input = document.getElementById(inputId);
            const icon = btn.querySelector('span');
            if (input.type === 'password') {
                input.type = 'text';
                icon.textContent = 'visibility_off';
            } else {
                input.type = 'password';
                icon.textContent = 'visibility';
            }
        }

        function sendOtp() {
            var email = document.getElementById('userEmail').value.trim();
            if (!email) {
                alert("Vui lòng nhập email trước khi lấy mã OTP!");
                document.getElementById('userEmail').focus();
                return;
            }

            var btnSend = document.getElementById('btnSendCode');
            var btnResend = document.getElementById('btnResend');
            var otpMsg = document.getElementById('otpMessage');
            
            btnSend.disabled = true;
            btnSend.textContent = "Đang gửi...";
            
            var token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            fetch('/Account/SendForgotPasswordOtp', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: new URLSearchParams({ 'email': email })
            })
            .then(r => r.json())
            .then(res => {
                if (res.success) {
                    otpMsg.style.color = '#16a34a';
                    otpMsg.textContent = res.message;
                    
                    document.getElementById('otpCode').disabled = false;
                    document.getElementById('otpCode').focus();
                    
                    btnSend.style.display = 'none';
                    document.getElementById('resendWrapper').style.display = 'block';
                    btnResend.style.display = 'none';
                    document.getElementById('countdownText').style.display = 'inline';
                    
                    startCountdown(60);
                } else {
                    otpMsg.style.color = '#ef4444';
                    otpMsg.textContent = res.message;
                    btnSend.disabled = false;
                    btnSend.textContent = "Gửi mã";
                }
            })
            .catch(err => {
                otpMsg.style.color = '#ef4444';
                otpMsg.textContent = "Lỗi mạng!";
                btnSend.disabled = false;
                btnSend.textContent = "Gửi mã";
            });
        }

        function startCountdown(seconds) {
            clearInterval(countdownInt);
            var span = document.getElementById('countdown');
            span.textContent = seconds;
            
            countdownInt = setInterval(() => {
                seconds--;
                span.textContent = seconds;
                if (seconds <= 0) {
                    clearInterval(countdownInt);
                    document.getElementById('countdownText').style.display = 'none';
                    document.getElementById('btnResend').style.display = 'inline';
                }
            }, 1000);
        }

        function formatOtp(input) {
            input.value = input.value.replace(/[^0-9]/g, '');
            if (input.value.length === 6) {
                verifyOtp(input.value);
            }
        }

        function verifyOtp(code) {
            var otpMsg = document.getElementById('otpMessage');
            var email = document.getElementById('userEmail').value.trim();
            otpMsg.style.color = '#6b7280';
            otpMsg.textContent = "Đang xác thực...";
            
            var token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            fetch('/Account/VerifyForgotPasswordOtp', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: new URLSearchParams({ 'email': email, 'code': code })
            })
            .then(r => r.json())
            .then(res => {
                if (res.success) {
                    otpMsg.style.color = '#16a34a';
                    otpMsg.innerHTML = '<span class="material-symbols-outlined" style="font-size:1.1rem; vertical-align:bottom;">check_circle</span> Xác thực thành công!';
                    
                    document.getElementById('userEmail').readOnly = true;
                    document.getElementById('otpCode').readOnly = true;
                    clearInterval(countdownInt);
                    document.getElementById('resendWrapper').style.display = 'none';

                    document.getElementById('newPassword').disabled = false;
                    document.getElementById('confirmPassword').disabled = false;
                    document.getElementById('btnSubmit').disabled = false;
                } else {
                    otpMsg.style.color = '#ef4444';
                    otpMsg.textContent = res.message;
                }
            })
            .catch(err => {
                otpMsg.style.color = '#ef4444';
                otpMsg.textContent = "Lỗi mạng!";
            });
        }

        function submitForm() {
            var newP = document.getElementById('newPassword').value;
            var confP = document.getElementById('confirmPassword').value;

            if (newP.length < 6) {
                alert("Mật khẩu mới phải có tối thiểu 6 ký tự!");
                return;
            }

            if (newP !== confP) {
                alert("Xác nhận mật khẩu mới không khớp!");
                return;
            }

            document.getElementById('forgotPasswordForm').submit();
        }
    </script>
</body>
</html>
