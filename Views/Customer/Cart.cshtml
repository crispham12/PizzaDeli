@{
    ViewData["Title"] = "Giỏ hàng của bạn";
}

<style>
    .cart-item-row {
        display: flex;
        gap: 1.5rem;
        padding-bottom: 2rem;
        margin-bottom: 2rem;
        border-bottom: 1px solid #f0ede9;
        animation: fadeIn 0.3s ease;
    }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }

    .qty-btn {
        width: 32px; height: 32px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.25rem; background: white; border-radius: 0.25rem;
        box-shadow: 0 1px 2px rgba(0,0,0,0.08);
        cursor: pointer; border: none;
        transition: background 0.15s;
    }
    .qty-btn:hover { background: #f1f5f9; }

    .remove-btn {
        display: flex; align-items: center; gap: 0.25rem;
        color: #ef4444; font-weight: 600; font-size: 0.875rem;
        background: none; border: none; cursor: pointer;
        transition: color 0.15s;
    }
    .remove-btn:hover { color: #b91c1c; }

    #empty-cart {
        text-align: center;
        padding: 4rem 0;
        color: var(--slate-400);
    }
    #empty-cart span.material-symbols-outlined { font-size: 4rem; display: block; margin-bottom: 1rem; }
</style>

<div class="container py-8" style="padding: 2rem 1.5rem;">
    <div style="display: grid; grid-template-columns: 1fr 340px; gap: 2.5rem; max-width: 1200px; margin: 0 auto;" id="cart-layout">

        <!-- Cart Items list -->
        <div>
            <div style="display: flex; align-items: center; justify-content: space-between; border-bottom: 2px solid #f0ede9; padding-bottom: 1rem; margin-bottom: 2rem;">
                <h1 style="font-size: 1.875rem; font-weight: 800; color: var(--slate-900);">
                    Giỏ hàng
                    <span id="cart-count-label" style="font-size: 1.125rem; color: var(--slate-500); font-weight: 600;">(0 sản phẩm)</span>
                </h1>
                <a asp-controller="Home" asp-action="Index" style="color: var(--primary); font-weight: 600; text-decoration: none;">Thêm món ăn mới</a>
            </div>

            <!-- Empty state -->
            <div id="empty-cart">
                <span class="material-symbols-outlined">shopping_cart</span>
                <p style="font-size: 1.125rem; font-weight: 600;">Giỏ hàng của bạn đang trống</p>
                <a asp-controller="Home" asp-action="Index"
                   style="display: inline-block; margin-top: 1rem; background: var(--primary); color: white; padding: 0.625rem 1.5rem; border-radius: 0.5rem; font-weight: 600; text-decoration: none;">
                    Khám phá thực đơn
                </a>
            </div>

            <!-- Items container (rendered by JS) -->
            <div id="cart-items-container"></div>
        </div>

        <!-- Checkout Summary -->
        <div>
            <div style="background: white; border-radius: 1rem; padding: 1.5rem; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); position: sticky; top: 100px;">
                <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 1.5rem;">Tóm tắt đơn hàng</h2>

                <div style="display: flex; justify-content: space-between; margin-bottom: 1rem; font-size: 0.9375rem;">
                    <span style="color: var(--slate-500);">Tạm tính</span>
                    <span id="subtotal-display" style="font-weight: 600;">0 ₫</span>
                </div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 1rem; font-size: 0.9375rem;">
                    <span style="color: var(--slate-500);">Phí giao hàng</span>
                    <span style="font-weight: 600; color: #16a34a;">Miễn phí</span>
                </div>

                <div style="border-top: 1px solid #f0ede9; border-bottom: 1px solid #f0ede9; padding: 1rem 0; margin: 1rem 0;">
                    <div style="display: flex; gap: 0.5rem;">
                        <input type="text" id="voucher-input" placeholder="Mã giảm giá"
                               style="flex: 1; padding: 0.625rem; border: 1px solid #e2e8f0; border-radius: 0.5rem; font-size: 0.875rem;" />
                        <button onclick="applyVoucherCart()" style="background: var(--slate-800); color: white; padding: 0 1rem; border-radius: 0.5rem; font-weight: 600; font-size: 0.875rem; cursor:pointer;">Áp dụng</button>
                    </div>
                    <p id="voucher-msg" style="font-size:0.8rem; margin-top:0.5rem;"></p>
                </div>

                <div style="display: flex; justify-content: space-between; margin-bottom: 1.5rem; font-size: 1.125rem;">
                    <span style="font-weight: 700;">Tổng cộng</span>
                    <span id="total-display" style="font-weight: 800; color: var(--primary); font-size: 1.5rem;">0 ₫</span>
                </div>

                <a asp-controller="Customer" asp-action="Checkout"
                   style="display: flex; justify-content: center; background: var(--primary); color: white; padding: 1rem; border-radius: 0.5rem; font-weight: 700; font-size: 1rem; text-decoration: none;">
                    Tiến hành thanh toán
                </a>
            </div>
        </div>

    </div>
</div>

<script>
const CART_KEY = 'pizzadeli_cart';

function getCart() {
    try { return JSON.parse(localStorage.getItem(CART_KEY)) || []; }
    catch { return []; }
}

function saveCart(cart) {
    localStorage.setItem(CART_KEY, JSON.stringify(cart));
}

function formatVND(amount) {
    return amount.toLocaleString('vi-VN') + ' ₫';
}

let discountAmount = 0;

function renderCart() {
    const cart = getCart();
    const container = document.getElementById('cart-items-container');
    const emptyEl = document.getElementById('empty-cart');
    const countLabel = document.getElementById('cart-count-label');

    container.innerHTML = '';

    if (cart.length === 0) {
        emptyEl.style.display = 'block';
        countLabel.textContent = '(0 sản phẩm)';
        updateSummary(0);
        return;
    }

    emptyEl.style.display = 'none';
    countLabel.textContent = `(${cart.length} sản phẩm)`;

    let subtotal = 0;
    cart.forEach((item, idx) => {
        subtotal += item.price * item.quantity;
        const row = document.createElement('div');
        row.className = 'cart-item-row';
        row.innerHTML = `
            <img src="${item.image || '/images/placeholder.png'}"
                 style="width:120px;height:120px;object-fit:cover;border-radius:1rem;flex-shrink:0;"
                 onerror="this.src='/images/placeholder.png'" />
            <div style="flex:1;display:flex;flex-direction:column;">
                <div style="display:flex;justify-content:space-between;">
                    <h3 style="font-size:1.125rem;font-weight:700;">${escapeHtml(item.name)}</h3>
                    <span style="font-size:1.25rem;font-weight:800;color:var(--primary);">${formatVND(item.price)}</span>
                </div>
                ${item.note ? `<p style="color:var(--slate-500);font-size:0.875rem;margin-top:0.25rem;">${escapeHtml(item.note)}</p>` : ''}
                <div style="margin-top:auto;display:flex;align-items:center;justify-content:space-between;">
                    <div style="display:flex;align-items:center;background:#f8fafc;border:1px solid #e2e8f0;border-radius:0.5rem;padding:0.25rem;">
                        <button class="qty-btn" onclick="changeQty(${idx}, -1)">−</button>
                        <span style="width:40px;text-align:center;font-weight:600;font-size:0.9375rem;" id="qty-${idx}">${item.quantity}</span>
                        <button class="qty-btn" onclick="changeQty(${idx}, 1)">+</button>
                    </div>
                    <button class="remove-btn" onclick="removeItem(${idx})">
                        <span class="material-symbols-outlined" style="font-size:1.125rem;">delete</span> Xóa
                    </button>
                </div>
            </div>
        `;
        container.appendChild(row);
    });

    updateSummary(subtotal);
}

function updateSummary(subtotal) {
    const total = Math.max(0, subtotal - discountAmount);
    document.getElementById('subtotal-display').textContent = formatVND(subtotal);
    document.getElementById('total-display').textContent = formatVND(total);
}

function changeQty(idx, delta) {
    const cart = getCart();
    cart[idx].quantity = Math.max(1, cart[idx].quantity + delta);
    saveCart(cart);
    renderCart();
}

function removeItem(idx) {
    const cart = getCart();
    cart.splice(idx, 1);
    saveCart(cart);
    renderCart();
    // Cập nhật badge toàn trang (nếu có)
    if (typeof updateCartBadge === 'function') updateCartBadge();
}

async function applyVoucherCart() {
    const code = document.getElementById('voucher-input').value.trim();
    const msgEl = document.getElementById('voucher-msg');
    if (!code) { msgEl.textContent = 'Vui lòng nhập mã voucher.'; msgEl.style.color = '#ef4444'; return; }

    const cart = getCart();
    const subtotal = cart.reduce((s, i) => s + i.price * i.quantity, 0);

    try {
        const res = await fetch('/Customer/ApplyVoucher', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `code=${encodeURIComponent(code)}&currentSubtotal=${subtotal}`
        });
        const data = await res.json();
        if (data.success) {
            discountAmount = data.discount;
            msgEl.textContent = `✓ ${data.message} (−${formatVND(data.discount)})`;
            msgEl.style.color = '#16a34a';
            updateSummary(subtotal);
        } else {
            discountAmount = 0;
            msgEl.textContent = data.message;
            msgEl.style.color = '#ef4444';
            updateSummary(subtotal);
        }
    } catch {
        msgEl.textContent = 'Lỗi kết nối, vui lòng thử lại.';
        msgEl.style.color = '#ef4444';
    }
}

function escapeHtml(str) {
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// Render ngay khi tải trang
document.addEventListener('DOMContentLoaded', renderCart);
</script>
