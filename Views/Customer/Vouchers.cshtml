@{
    ViewData["Title"] = "Voucher của tôi";
}

<div class="container py-8" style="padding: 2rem 1.5rem;">
    <div style="max-width: 800px; margin: 0 auto; background: white; border-radius: 1rem; padding: 2rem; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);">
        <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #f0ede9; padding-bottom: 1.5rem; margin-bottom: 2rem;">
            <div>
                <h1 style="font-size: 1.875rem; font-weight: 800; color: var(--slate-900); margin-bottom: 0.5rem;">Kho Voucher</h1>
                <p style="color: var(--slate-500); font-weight: 500;">Mã giảm giá dành riêng cho bạn</p>
            </div>
            <a asp-action="Profile" asp-controller="Customer" style="display: inline-flex; align-items: center; gap: 0.5rem; color: var(--primary); font-weight: 600; text-decoration: none;">
                <span class="material-symbols-outlined">arrow_back</span> Trở lại hồ sơ
            </a>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">

            <!-- Dummy Voucher 1 -->
            <div style="border: 2px dashed var(--primary-30); border-radius: 0.75rem; padding: 1.5rem; position: relative; background: var(--primary-05);">
                <span class="material-symbols-outlined" style="position: absolute; right: 1rem; top: 1rem; font-size: 2.5rem; color: var(--primary-20);">loyalty</span>
                <span style="font-size: 0.75rem; font-weight: 700; color: white; background: var(--primary); padding: 0.25rem 0.5rem; border-radius: 0.25rem; display: inline-block; margin-bottom: 0.75rem;">MỚI TẠO TÀI KHOẢN</span>
                <h3 style="font-size: 1.25rem; font-weight: 800; margin-bottom: 0.25rem; color: var(--slate-900);">Giảm 15% tổng bill</h3>
                <p style="font-size: 0.875rem; color: var(--slate-500); margin-bottom: 1rem;">Áp dụng cho đơn hàng đầu tiên (Tối đa $5)</p>
                <div style="display: flex; align-items: center; justify-content: space-between; border-top: 1px dashed var(--primary-30); padding-top: 1rem;">
                    <span style="font-size: 0.875rem; font-weight: 600; font-family: monospace;">NEW15OFF</span>
                    <button style="font-size: 0.875rem; font-weight: 700; color: var(--primary); background: transparent; border: none; cursor: pointer; text-decoration: underline;">Sao chép mã</button>
                </div>
            </div>

            <!-- Dummy Voucher 2 -->
            <div style="border: 1px solid #e2e8f0; border-radius: 0.75rem; padding: 1.5rem; position: relative; background: #f8fafc;">
                <span class="material-symbols-outlined" style="position: absolute; right: 1rem; top: 1rem; font-size: 2.5rem; color: var(--slate-200);">local_shipping</span>
                <span style="font-size: 0.75rem; font-weight: 700; color: #1e3a8a; background: #dbeafe; padding: 0.25rem 0.5rem; border-radius: 0.25rem; display: inline-block; margin-bottom: 0.75rem;">FREE SHIP</span>
                <h3 style="font-size: 1.25rem; font-weight: 800; margin-bottom: 0.25rem; color: var(--slate-900);">Miễn phí vận chuyển</h3>
                <p style="font-size: 0.875rem; color: var(--slate-500); margin-bottom: 1rem;">Dành cho đơn từ $30 trở lên</p>
                <div style="display: flex; align-items: center; justify-content: space-between; border-top: 1px dashed #cbd5e1; padding-top: 1rem;">
                    <span style="font-size: 0.875rem; font-weight: 600; font-family: monospace;">FREESHIP30</span>
                    <button style="font-size: 0.875rem; font-weight: 700; color: var(--slate-600); background: transparent; border: none; cursor: pointer; text-decoration: underline;">Sao chép mã</button>
                </div>
            </div>

        </div>
    </div>
</div>
