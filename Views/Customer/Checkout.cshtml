                                            <div style="flex:1; min-width:180px; display:flex; flex-direction:column; gap:0.75rem;">
                                                <div>
                                                    <div style="font-size:0.72rem; font-weight:700; color:#7e22ce; letter-spacing:0.05em; margin-bottom:0.25rem;">SỐ TÀI KHOẢN TP BANK</div>
                                                    <div style="display:flex; align-items:center; gap:0.5rem;">
                                                        <span id="bank-account-number" style="font-size:1.2rem; font-weight:800; color:#1e293b; letter-spacing:0.04em;">0346 765 950</span>
                                                        <button type="button" onclick="copyBankAccount()" title="Sao chép" style="background:none;border:none;cursor:pointer;color:#7e22ce;padding:0;display:flex;align-items:center;">
                                                            <span class="material-symbols-outlined" style="font-size:1.1rem;">content_copy</span>
                                                        </button>
                                                    </div>
                                                </div>
                                                <div>
                                                    <div style="font-size:0.72rem; font-weight:700; color:#64748b; letter-spacing:0.05em; margin-bottom:0.25rem;">TÊN TÀI KHOẢN</div>
                                                    <div style="font-weight:700; color:#1e293b;">PIZZA DELI VN</div>
                                                </div>
                                                <div>
                                                    <div style="font-size:0.72rem; font-weight:700; color:#64748b; letter-spacing:0.05em; margin-bottom:0.25rem;">SỐ TIỀN</div>
                                                    <div id="bank-amount" style="font-weight:800; color:#7e22ce; font-size:1.05rem;">—</div>
