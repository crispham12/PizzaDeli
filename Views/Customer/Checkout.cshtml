                                                <div>
                                                    <div style="font-size:0.72rem; font-weight:700; color:#64748b; letter-spacing:0.05em; margin-bottom:0.25rem;">NỘI DUNG CHUYỂN KHOẢN</div>
                                                    <div style="font-size:0.85rem; font-weight:600; color:#475569; background:#fff; border:1px solid #d8b4fe; border-radius:8px; padding:0.4rem 0.75rem; display:flex; align-items:center; gap:0.4rem;">
                                                        <span id="bank-content">CK PIZZADELI</span>
                                                        <button type="button" onclick="copyBankContent()" title="Sao chép" style="background:none;border:none;cursor:pointer;color:#7e22ce;padding:0;display:flex;align-items:center;margin-left:auto;">
                                                            <span class="material-symbols-outlined" style="font-size:1rem;">content_copy</span>
                                                        </button>
                                                    </div>
