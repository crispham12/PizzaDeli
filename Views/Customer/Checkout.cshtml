                                        <div style="background:#a82fa2; padding:0.75rem 1.25rem; display:flex; align-items:center; gap:0.6rem;">
                                            <span class="material-symbols-outlined" style="color:#fff; font-size:1.25rem;">wallet</span>
                                            <span style="color:#fff; font-weight:700; font-size:0.95rem;">Thanh toán qua Momo</span>
                                        </div>
                                        <div style="padding:1.5rem; display:flex; flex-wrap:wrap; gap:1.5rem; align-items:flex-start;">
                                            <!-- QR Code -->
                                            <div style="flex-shrink:0; text-align:center;">
                                                <div style="width:140px; height:140px; background:#fff; border-radius:12px; border:1px solid #fbcfe8; display:flex; align-items:center; justify-content:center; overflow:hidden; box-shadow:0 2px 8px rgba(168,47,162,0.10);">
                                                    <img src="/images/zalopay_qr.png"
                                                         alt="Momo QR" style="width:128px;height:128px;object-fit:contain;"
