                                                </div>
                                                <p style="font-size:0.72rem; color:#64748b; margin-top:0.5rem; font-weight:600;">Quét mã để thanh toán</p>
                                            </div>
                                            <!-- Account Info -->
                                            <div style="flex:1; min-width:180px; display:flex; flex-direction:column; gap:0.75rem;">
                                                <div>
                                                    <div style="font-size:0.72rem; font-weight:700; color:#a82fa2; letter-spacing:0.05em; margin-bottom:0.25rem;">SỐ ĐIỆN THOẠI MOMO</div>
                                                    <div style="display:flex; align-items:center; gap:0.5rem;">
