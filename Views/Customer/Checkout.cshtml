                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- ZaloPay Payment Info Box -->
                                    <div id="zalopay-info-box" style="display:none; margin-top:1.5rem; border:1.5px solid #0068ff22; border-radius:16px; background:linear-gradient(135deg,#f0f7ff 0%,#e8f3ff 100%); overflow:hidden; animation: fadeIn 0.3s ease;">
                                        <div style="background:#0068ff; padding:0.75rem 1.25rem; display:flex; align-items:center; gap:0.6rem;">
                                            <span class="material-symbols-outlined" style="color:#fff; font-size:1.25rem;">qr_code_2</span>
                                            <span style="color:#fff; font-weight:700; font-size:0.95rem;">Thanh toán qua TP bank</span>
