                                            <!-- QR Code -->
                                            <div style="flex-shrink:0; text-align:center;">
                                                <div style="width:140px; height:140px; background:#fff; border-radius:12px; border:1px solid #dbeafe; display:flex; align-items:center; justify-content:center; overflow:hidden; box-shadow:0 2px 8px rgba(0,104,255,0.10);">
