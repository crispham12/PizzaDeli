                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Panel: COD -->
                                <div class="payment-panel" id="panel-cod">
                                    <div style="display:flex; flex-direction: column; align-items:center; color: var(--slate-600); padding: 2rem;">
                                        <span class="material-symbols-outlined" style="font-size: 3rem; color: var(--primary); margin-bottom: 1rem;">local_shipping</span>
                                        <p style="text-align:center; font-weight: 500;">Thanh toán bằng tiền mặt khi nhận hàng.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- ========================================== -->
                    <!-- BƯỚC 3: REVIEW                             -->
                    <!-- ========================================== -->
                    <div id="step-review-content" style="display: none;">
                        <h3 class="section-title" style="margin-bottom: 0.5rem; color: #1e293b; font-size: 1.5rem;">Review Your Items</h3>
                        <p style="color: var(--slate-500); font-size: 0.875rem; margin-bottom: 2rem;">Your feedback helps us improve. Please rate and review the items from your order.</p>

                        <div id="reviewItemsContainer">
                            <!-- JS load items to review -->
                        </div>
                        
                        <div style="text-align: right; margin-top: 1rem;">
                            <button type="button" class="btn-back-link" onclick="window.location.href='/'" style="margin-right: 1.5rem; margin-bottom: 0;">Quay lại trang chủ</button>
                            <button type="button" class="btn-place-order" style="display: inline-block; width: auto; padding: 0.75rem 2rem;" onclick="submitAllReviews()">Gửi tất cả đánh giá</button>
                        </div>
                    </div>

                    <!-- Dữ liệu ẩn giỏ hàng để gửi lên server -->
                    <input type="hidden" name="cartJson" id="cartJsonInput" value="" />
                    <input type="hidden" name="voucherCode" id="hiddenVoucherCode" value="" />
                    <input type="hidden" name="shippingAddress" id="shippingAddressInput" value="" />
                </form>
            </div>

            <!-- Cột phải: Order Summary -->
            <div class="checkout-sidebar">
                <div class="summary-card">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                        <h3 class="summary-title" style="margin-bottom: 0;">Tóm tắt đơn hàng</h3>
                        <div style="display: flex; gap: 0.5rem; align-items: center;">
                            <a href="javascript:goToAddMore()" id="btnSidebarAddMore" style="font-size: 0.85rem; font-weight: 600; color:var(--primary); text-decoration: none; padding: 0.3rem 0.6rem; border-radius: 6px; border: 1px solid var(--primary);">+ Đặt thêm món</a>
                            <button type="button" onclick="reorderLatest()" id="btnSidebarReorder" title="Làm mới giỏ hàng theo đơn cũ" style="display: none; font-size: 0.85rem; font-weight: 600; color:#5c433b; align-items: center; justify-content: center; background: white; border: 1px solid #5c433b; padding: 0.25rem 0.5rem; border-radius: 6px; cursor: pointer;">
                                <span class="material-symbols-outlined" style="font-size: 1.1rem; margin-right: 0.2rem;">replay</span> Đặt lại đơn
                            </button>
                        </div>
                    </div>
                    
                    <!-- Chứa danh sách SP bằng JS -->
                    <div class="checkout-items" id="checkoutItemsList">
                        <div class="text-center" style="padding: 1rem; color: #888;">Đang tải giỏ hàng...</div>
                    </div>

                    <!-- Voucher box -->
                    <div class="voucher-box" id="step-voucher-box" style="display:flex; flex-direction: column; gap: 0.5rem; margin: 1.5rem 0; padding: 1.5rem 0; border-top: 1px solid #f1f5f9; border-bottom: 1px solid #f1f5f9; border-left:none; border-right:none; border-width: 1px 0;">
                        <label style="font-size: 0.75rem; font-weight: 700; color: #64748b; letter-spacing: 0.05em; display:block;">MÃ VOUCHER</label>
                        <div style="display: flex; gap: 0.5rem;">
                            <input type="text" id="voucherCode" placeholder="Nhập mã" style="flex: 1; border: 1px solid #e2e8f0; border-radius: 999px; padding: 0.625rem 1rem; outline: none; transition: border-color 0.2s; font-size: 0.875rem; color: #1e293b;">
                            <button type="button" class="btn-apply-voucher" onclick="applyCheckoutVoucher()" style="background-color: var(--primary); color: white; border-radius: 999px; padding: 0.5rem 1.5rem; font-weight: 600; border: none; cursor: pointer; font-size: 0.875rem;">Dùng</button>
                        </div>
                    </div>

                    <div class="summary-totals">
                        <div class="summary-row">
                            <span>Tạm tính</span>
                            <span id="checkoutSubtotal">0 ₫</span>
                        </div>
                        <div class="summary-row">
                            <span>Phí giao hàng</span>
                            <span id="checkoutShipping" style="color: #10b981; font-weight: 500;">Miễn phí</span>
                        </div>
                        <div class="summary-row discount-row" style="display:none;" id="checkoutDiscountRow">
                            <span>Giảm giá</span>
                            <span id="checkoutDiscount" class="text-danger">0 ₫</span>
                        </div>
                        <div class="summary-row grand-total">
                            <span style="font-size: 1.25rem;">Tổng cộng</span>
                            <span id="checkoutGrandTotal" class="primary-color text-bold" style="font-size: 1.25rem;">0 ₫</span>
                        </div>
                    </div>

                    <!-- Action Button -->
                    <button type="button" id="btnActionFlow" class="btn-place-order" onclick="gotoNextStep()" style="font-size: 1.05rem; padding: 1.15rem;">
                        Tiếp tục thanh toán <span class="material-symbols-outlined">chevron_right</span>
                    </button>

                    <!-- Success Popup Modal -->
                    <div id="orderSuccessModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999; align-items:center; justify-content:center;">
                        <div style="background:#fff; border-radius:20px; padding:2.5rem 2rem; text-align:center; max-width:400px; width:90%; position:relative; box-shadow:0 20px 60px rgba(0,0,0,0.2);">
                            <div style="width:72px;height:72px;background:#dcfce7;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;">
                                <span class="material-symbols-outlined" style="font-size:2.5rem;color:#16a34a;font-variation-settings:'FILL' 1;">check_circle</span>
                            </div>
                            <h2 style="font-size:1.5rem;font-weight:800;color:#1e293b;margin-bottom:0.5rem;">Đặt hàng thành công!</h2>
                            <p style="color:#64748b;margin-bottom:0.25rem;">Đơn hàng của bạn đã được tiếp nhận.</p>
                            <p id="successOrderCode" style="font-weight:700;color:#5c433b;font-size:1.1rem;margin-bottom:2rem;"></p>
                            <button onclick="goToReviews()" style="background:#5c433b;color:#fff;border:none;border-radius:12px;padding:0.875rem 2rem;font-size:1rem;font-weight:700;cursor:pointer;width:100%;transition:background 0.2s;">
                                <span class="material-symbols-outlined" style="vertical-align:middle;font-size:1.125rem;margin-right:0.4rem;">star</span>
                                Xem & Đánh giá sản phẩm
                            </button>
                            <a href="/Customer/Orders" style="display:block;margin-top:1rem;color:#64748b;font-size:0.875rem;font-weight:600;text-decoration:none;">Xem đơn hàng của tôi →</a>
                        </div>
                    </div>
                    
                    <p class="secure-text" style="margin-top: 1rem;">
                        <span class="material-symbols-outlined" style="vertical-align: middle; font-size: 0.85rem;">lock</span>
                        Thanh toán SSL bảo mật
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentStep = 1; // 1: Shipping, 2: Payment, 3: Review
        let currentDiscount = 0;
        let tempReviewItems = []; // Lưu lại dữ liệu để dùng cho Step 3

        const SHIPPING_FEES = {
            'standard': 15000,
            'express': 35000
        };

        const urlParams = new URLSearchParams(window.location.search);
        const isBuyNowCheckout = urlParams.get('mode') === 'buynow';

        // Lấy danh sách sản phẩm từ giỏ hàng thực
        let CHECKOUT_ITEMS = [];
        if (isBuyNowCheckout) {
            const raw = sessionStorage.getItem('buynow_item');
            if (raw) {
                try { 
                    CHECKOUT_ITEMS = JSON.parse(raw); 
                    if (!Array.isArray(CHECKOUT_ITEMS)) CHECKOUT_ITEMS = [CHECKOUT_ITEMS];
                } catch(e) { CHECKOUT_ITEMS = []; }
            }
        }

        document.addEventListener('DOMContentLoaded', function() {
            renderCheckoutItems();

            // Tabs Logic
            const tabs = document.querySelectorAll('.payment-tab');
            const panels = document.querySelectorAll('.payment-panel');
            const mainPaymentInput = document.getElementById('mainPaymentMethod');

            tabs.forEach(tab => {
                tab.addEventListener('click', () => {
                    tabs.forEach(t => t.classList.remove('active'));
                    panels.forEach(p => p.classList.remove('active'));
                    
                    tab.classList.add('active');
                    const target = tab.dataset.target;
                    document.getElementById(target).classList.add('active');

                    // Map logic cho server
                    if(target === 'panel-card') mainPaymentInput.value = 'card';
                    if(target === 'panel-ewallet') mainPaymentInput.value = 'momo'; // Default
                    if(target === 'panel-bank') mainPaymentInput.value = 'bank';
                    if(target === 'panel-cod') mainPaymentInput.value = 'cod';

                    // Ẩn box khi chuyển khỏi tab ví điện tử
                    const momoBox = document.getElementById('momo-info-box');
                    const zaloBox = document.getElementById('zalopay-info-box');
                    if (target !== 'panel-ewallet') {
                        if (momoBox) momoBox.style.display = 'none';
                        if (zaloBox) zaloBox.style.display = 'none';
                    }
                    // Khi vào lại tab ví: hiển thị mặc định
                    if (target === 'panel-ewallet') {
                        const momoCard = document.querySelector('#ewalletSelector .way-card');
                        if (momoCard) selectEwallet('momo', momoCard);
                    }
                    // Cập nhật tab Bank nếu được chọn
                    if (target === 'panel-bank') {
                        updateBankPanel();
                    }
                });
            });

            // Gắn sự kiện khi sửa SĐT sẽ tự động cập nhật Nội dung CK ở các tab hiện tại
            document.getElementById('phone')?.addEventListener('input', function() {
                const val = mainPaymentInput.value;
                if (val === 'bank') updateBankPanel();
                else if (val === 'momo' || val === 'zalopay') {
                    const activeWallet = document.querySelector('#ewalletSelector .way-card.selected');
                    if (activeWallet) selectEwallet(val, activeWallet);
                }
            });
        });

        function selectEwallet(wallet, el) {
            document.querySelectorAll('#ewalletSelector .way-card').forEach(c => c.classList.remove('selected'));
            if(el) el.classList.add('selected');
            document.getElementById('mainPaymentMethod').value = wallet;

            const momoBox = document.getElementById('momo-info-box');
            const zaloBox = document.getElementById('zalopay-info-box');
            
            const totalEl = document.getElementById('checkoutGrandTotal');
            const phone = document.getElementById('phone')?.value.trim();

            if (wallet === 'zalopay') {
                if (zaloBox) {
                    document.getElementById('zalo-amount').textContent = totalEl ? totalEl.textContent : '—';
                    document.getElementById('zalo-content').textContent = phone ? 'ZALOPAY ' + phone : 'ZALOPAY PIZZADELI';
                    zaloBox.style.display = 'block'; 
                    //zaloBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                }
                if (momoBox) momoBox.style.display = 'none';
            } else if (wallet === 'momo') {
                if (momoBox) {
                    document.getElementById('momo-amount').textContent = totalEl ? totalEl.textContent : '—';
                    document.getElementById('momo-content').textContent = phone ? 'MOMO ' + phone : 'MOMO PIZZADELI';
                    momoBox.style.display = 'block';
                    //momoBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                }
                if (zaloBox) zaloBox.style.display = 'none';
            } else {
                if (zaloBox) zaloBox.style.display = 'none';
                if (momoBox) momoBox.style.display = 'none';
            }
        }

        function copyMomoAccount() {
            navigator.clipboard.writeText('0778118984').then(() => showCopyToast('Đã sao chép số điện thoại!'));
        }
        function copyMomoContent() {
            const txt = document.getElementById('momo-content')?.textContent || '';
            navigator.clipboard.writeText(txt).then(() => showCopyToast('Đã sao chép nội dung CK!'));
        }
        function copyZaloAccount() {
            navigator.clipboard.writeText('0346765950').then(() => showCopyToast('Đã sao chép số tài khoản!'));
        }
        function copyZaloContent() {
            const txt = document.getElementById('zalo-content')?.textContent || '';
            navigator.clipboard.writeText(txt).then(() => showCopyToast('Đã sao chép nội dung CK!'));
        }

        function updateBankPanel() {
            const totalText = document.getElementById('checkoutGrandTotal')?.textContent || '0';
            const totalNumber = totalText.replace(/\D/g, ''); // Extract only digits
            const phone = document.getElementById('phone')?.value.trim();
            const content = phone ? 'CK ' + phone : 'CK PIZZADELI';
            
            // Cập nhật text UI
            document.getElementById('bank-amount').textContent = totalText;
            document.getElementById('bank-content').textContent = content;
            
            // Link VietQR form động: tpbank-0346765950
            const qrUrl = `https://img.vietqr.io/image/tpbank-0346765950-compact2.png?amount=${totalNumber}&addInfo=${encodeURIComponent(content)}&accountName=PIZZADELIVN`;
            const qrImg = document.getElementById('bank-qr-img');
            if (qrImg) qrImg.src = qrUrl;
        }

        function copyBankAccount() {
            navigator.clipboard.writeText('0346765950').then(() => showCopyToast('Đã sao chép số tài khoản!'));
        }
        function copyBankContent() {
            const txt = document.getElementById('bank-content')?.textContent || '';
            navigator.clipboard.writeText(txt).then(() => showCopyToast('Đã sao chép nội dung CK!'));
        }

        function showCopyToast(msg) {
            let t = document.getElementById('copy-toast');
            if (!t) {
                t = document.createElement('div');
                t.id = 'copy-toast';
                t.style.cssText = 'position:fixed;bottom:2rem;left:50%;transform:translateX(-50%);background:#1e293b;color:#fff;padding:0.6rem 1.4rem;border-radius:999px;font-size:0.875rem;font-weight:600;z-index:9999;transition:opacity 0.3s;';
                document.body.appendChild(t);
            }
            t.textContent = msg;
            t.style.opacity = '1';
            clearTimeout(t._timer);
            t._timer = setTimeout(() => t.style.opacity = '0', 2000);
        }

        // Logic Lùi Bước
        function goBackStep() {
            if(currentStep === 2) {
                // Đang ở Payment, quay lại Shipping
                document.getElementById('step-payment-content').style.display = 'none';
                document.getElementById('step-shipping-content').style.display = 'block';
                
                document.getElementById('stepperPayment').classList.remove('active');
                document.getElementById('stepperSubtitle').textContent = 'Bước 1 trong 3: Nhập thông tin giao hàng của bạn';
                document.getElementById('btnActionFlow').innerHTML = 'Tiếp tục thanh toán <span class="material-symbols-outlined">chevron_right</span>';
                
                // Hiển thị lại nút Home, ẩn nút Back Step
                document.getElementById('btnGoBack').style.display = 'none';
                if(document.getElementById('btnHomeBack')) document.getElementById('btnHomeBack').style.display = 'inline-flex';
                
                currentStep = 1;

            } else if(currentStep === 3) {
                // Đang ở Review, quay lại Payment
                document.getElementById('step-review-content').style.display = 'none';
                document.getElementById('step-payment-content').style.display = 'block';
                
                document.getElementById('stepperReview').classList.remove('active');
                document.getElementById('stepperSubtitle').textContent = 'Bước 2 trong 3: Lựa chọn Phương thức thanh toán';
                document.getElementById('btnActionFlow').innerHTML = 'Tiếp tục xác nhận <span class="material-symbols-outlined">chevron_right</span>';
                document.getElementById('btnActionFlow').style.display = 'block'; // Ensure button visible
                currentStep = 2;
            }
            window.scrollTo({top: 0, behavior: 'smooth'});
        }

        // ---- Inline validation helpers ----
        function showFieldError(inputEl, errId, message) {
            inputEl.classList.add('input-error');
            const span = document.getElementById(errId);
            if (span) span.textContent = message;
            // Tự xóa khi user gõ
            inputEl.addEventListener('input', function clearOnType() {
                clearFieldError(inputEl, errId);
                inputEl.removeEventListener('input', clearOnType);
            }, { once: true });
        }

        function clearFieldError(inputEl, errId) {
            inputEl.classList.remove('input-error');
            const span = document.getElementById(errId);
            if (span) span.textContent = '';
        }

        function clearAllFieldErrors() {
            [['fullName','err-fullName'],['phone','err-phone'],['address','err-address']].forEach(([id, errId]) => {
                const el = document.getElementById(id);
                if (el) clearFieldError(el, errId);
            });
        }

        // Logic Chuyển Bước
        function gotoNextStep() {
            if (currentStep === 1) {
                // Validate inline
                const fName    = document.getElementById('fullName');
                const fPhone   = document.getElementById('phone');
                const fAddress = document.getElementById('address');

                clearAllFieldErrors();
                let hasError = false;

                if (!fAddress.value.trim()) {
                    showFieldError(fAddress, 'err-address', 'Vui lòng nhập địa chỉ giao hàng.');
                    hasError = true;
                }
                if (!fPhone.value.trim()) {
                    showFieldError(fPhone, 'err-phone', 'Vui lòng nhập số điện thoại.');
                    hasError = true;
                }
                if (!fName.value.trim()) {
                    showFieldError(fName, 'err-fullName', 'Vui lòng nhập họ và tên.');
                    hasError = true;
                }
                if (hasError) {
                    // Scroll đến lỗi đầu tiên
                    const firstErr = document.querySelector('.input-error');
                    if (firstErr) firstErr.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    return;
                }

                // Chuyển UI sang Payment
                document.getElementById('step-shipping-content').style.display = 'none';
                document.getElementById('step-payment-content').style.display = 'block';
                
                // Update Stepper
                document.getElementById('stepperPayment').classList.add('active');
                document.getElementById('stepperSubtitle').textContent = 'Bước 2 trong 3: Lựa chọn Phương thức thanh toán';
                document.getElementById('btnActionFlow').innerHTML = 'Xác nhận <span class="material-symbols-outlined">check_circle</span>';
                
                // Hiện nút lùi step, giấu nút Home back
                document.getElementById('btnGoBack').style.display = 'inline-flex';
                if(document.getElementById('btnHomeBack')) document.getElementById('btnHomeBack').style.display = 'none';
                
                window.scrollTo({top: 0, behavior: 'smooth'});
                currentStep = 2;

            } else if (currentStep === 2) {
                // Giao diện Payment => Đặt hàng ngay
                submitOrder();
                return;

            } else if (currentStep === 3) {
                // Quay lùi UI về Step 1
                document.getElementById('step-review-content').style.display = 'none';
                document.getElementById('step-shipping-content').style.display = 'block';
                
                document.getElementById('stepperReview').classList.remove('active');
                document.getElementById('stepperPayment').classList.remove('active');
                document.getElementById('stepperSubtitle').textContent = 'Bước 1 trong 3: Nhập thông tin giao hàng của bạn';
                document.getElementById('btnActionFlow').innerHTML = 'Tiếp tục thanh toán <span class="material-symbols-outlined">chevron_right</span>';
                
                document.getElementById('btnGoBack').style.display = 'none';
                if(document.getElementById('btnHomeBack')) document.getElementById('btnHomeBack').style.display = 'inline-flex';
                
                window.scrollTo({top: 0, behavior: 'smooth'});
                currentStep = 1;
            }
        }

        function buildReviewItems() {
            const container = document.getElementById('reviewItemsContainer');
            const cart = tempReviewItems;
            let html = '';
            
            cart.forEach(item => {
                html += `
                <div class="review-item-card" data-product-id="${item.id}">
                    <img src="${item.image || '/images/placeholder.png'}" class="review-item-img" onerror="this.src='/images/placeholder.png'">
                    <div class="review-item-content">
                        <div class="review-item-title">${item.name}</div>
                        <div class="review-item-meta">Chất lượng sản phẩm</div>
                        <div class="review-rating data-stars" data-rating="0">
                            <span class="material-symbols-outlined star empty" style="color:#cbd5e1; font-variation-settings: 'FILL' 0; transition: color 0.2s; cursor:pointer;" data-val="1">star</span>
                            <span class="material-symbols-outlined star empty" style="color:#cbd5e1; font-variation-settings: 'FILL' 0; transition: color 0.2s; cursor:pointer;" data-val="2">star</span>
                            <span class="material-symbols-outlined star empty" style="color:#cbd5e1; font-variation-settings: 'FILL' 0; transition: color 0.2s; cursor:pointer;" data-val="3">star</span>
                            <span class="material-symbols-outlined star empty" style="color:#cbd5e1; font-variation-settings: 'FILL' 0; transition: color 0.2s; cursor:pointer;" data-val="4">star</span>
                            <span class="material-symbols-outlined star empty" style="color:#cbd5e1; font-variation-settings: 'FILL' 0; transition: color 0.2s; cursor:pointer;" data-val="5">star</span>
                        </div>
                        <label style="font-size: 0.75rem; font-weight: 700; color: #1e293b; margin-bottom: 0.5rem; display:block;">Nhận xét của bạn</label>
                        <textarea class="review-textarea" rows="3" placeholder="Chia sẻ cảm nhận của bạn về món này..."></textarea>
                    </div>
                </div>
                `;
            });
            container.innerHTML = html;
        }

        function attachStarRating() {
            document.querySelectorAll('.data-stars').forEach(container => {
                const stars = container.querySelectorAll('.star');
                stars.forEach((star, index) => {
                    star.addEventListener('click', () => {
                        container.dataset.rating = index + 1; // Lưu rating
                        // Reset tắt màu toàn bộ sao
                        stars.forEach(s => {
                            s.classList.add('empty');
                            s.style.color = '#cbd5e1';
                            s.style.fontVariationSettings = "'FILL' 0";
                        });
                        // Bật vàng các sao từ đầu đến index
                        for(let i=0; i<=index; i++) {
                            stars[i].classList.remove('empty');
                            stars[i].style.color = '#fbbf24'; // yellow highlight
                            stars[i].style.fontVariationSettings = "'FILL' 1";
                        }
                    });
                });
            });
        }

        async function submitAllReviews() {
            const reviews = [];
            const cards = document.querySelectorAll('.review-item-card');
            cards.forEach(card => {
                const pid = card.dataset.productId;
                const starBox = card.querySelector('.data-stars');
                const rating = parseInt(starBox.dataset.rating) || 0;
                const content = card.querySelector('.review-textarea').value;
                if(rating > 0) {
                    reviews.push({ ProductId: pid, Rating: rating, Content: content });
                }
            });

            if (reviews.length > 0) {
                try {
                    const btn = document.querySelector('.btn-place-order[onclick^="submitAllReviews"]');
                    if(btn) btn.innerHTML = '<span class="material-symbols-outlined" style="animation:spin 1s linear infinite;">progress_activity</span> Đang gửi...';

                    await fetch('/Customer/SubmitMultipleReviews', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify(reviews)
                    });
                } catch(e) {
                }
            }

            alert('Đã gửi thành công đánh giá của bạn. Cảm ơn vì đã mua sắm tại PizzaDeli!');
            if (window.PizzaCart) window.PizzaCart.renderCartDrawer();
            window.location.href = '/Customer/Orders'; 
        }

        function goToAddMore() {
            const modeQuery = isBuyNowCheckout ? '&mode=buynow' : '';
            window.location.href = '/?addmore=1' + modeQuery;
        }

        function renderCheckoutItems() {
            const container = document.getElementById('checkoutItemsList');

            // Load items from cart
            if (!isBuyNowCheckout) {
                if(!window.PizzaCart) {
                    container.innerHTML = '<p>Không thể tải giỏ hàng.</p>';
                    return;
                }
                CHECKOUT_ITEMS = window.PizzaCart.getCart();
            }

            if (CHECKOUT_ITEMS.length === 0) {
                container.innerHTML = '<p style="text-align:center; padding: 2rem;">Không có sản phẩm. Mời bạn quay lại trang chủ chọn món.</p>';
                document.getElementById('btnActionFlow').disabled = true;
                return;
            }

            let html = '';
            let subtotal = 0;
            CHECKOUT_ITEMS.forEach(item => {
                const price = parseFloat(item.price) || 0;
                const qty = parseInt(item.quantity) || 1;
                subtotal += price * qty;

                html += `
                <div class="c-item">
                    <img src="${item.image || '/images/placeholder.png'}" class="c-item-img" onerror="this.src='/images/placeholder.png'">
                    <div class="c-item-info">
                        <div class="c-item-name" style="font-size: 0.85rem;">${item.name}</div>
                        <div class="c-item-qty" style="font-size: 0.75rem; color:#64748b;">x${qty}</div>
                    </div>
                    <div class="c-item-price" style="font-size: 0.875rem; color:#1e293b;">${price.toLocaleString('vi-VN')} ₫</div>
                </div>
                `;
            });

            container.innerHTML = html;

            // Tính phí
            const shippingMethod = document.querySelector('input[name="deliveryMethod"]:checked').value;
            const shippingFee = SHIPPING_FEES[shippingMethod] || 15000;
            updateTotals(subtotal, shippingFee, currentDiscount);

            // Gắn sự kiện thay đổi phương thức giao hàng
            document.querySelectorAll('input[name="deliveryMethod"]').forEach(el => {
                el.addEventListener('change', function() {
                    updateTotals(subtotal, SHIPPING_FEES[this.value] || 15000, currentDiscount);
                });
            });
        }

        function updateTotals(subtotal, shipping, discount) {
            document.getElementById('checkoutSubtotal').textContent = subtotal.toLocaleString('vi-VN') + ' ₫';
            document.getElementById('checkoutShipping').textContent = shipping.toLocaleString('vi-VN') + ' ₫';
            
            const total = subtotal + shipping - discount;
            document.getElementById('checkoutGrandTotal').textContent = Math.max(0, total).toLocaleString('vi-VN') + ' ₫';

            if(discount > 0) {
                const dRow = document.getElementById('checkoutDiscountRow');
                dRow.style.display = 'flex';
                document.getElementById('checkoutDiscount').textContent = '-' + discount.toLocaleString('vi-VN') + ' ₫';
            }
        }

        async function applyCheckoutVoucher() {
            const code = document.getElementById('voucherCode').value;
            if(!code) return;
            
            // Tính subtotal hiện tại từ giỏ hàng để check min order value
            const cart = window.PizzaCart ? window.PizzaCart.getCart() : [];
            let subtotal = 0;
            cart.forEach(item => {
                subtotal += (parseFloat(item.price) || 0) * (parseInt(item.quantity) || 1);
            });

            try {
                const response = await fetch('/Customer/ApplyVoucher', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: new URLSearchParams({ code: code, currentSubtotal: subtotal })
                });
                
                const data = await response.json();
                if (data.success) {
                    currentDiscount = data.discount;
                    document.getElementById('hiddenVoucherCode').value = code; // Send to backend when Complete
                    alert(data.message);
                    renderCheckoutItems(); // Re-render to update
                } else {
                    alert(data.message);
                    currentDiscount = 0;
                    document.getElementById('hiddenVoucherCode').value = '';
                    renderCheckoutItems();
                }
            } catch(e) {
                alert('Lỗi khi áp dụng mã giảm giá.');
                console.error(e);
            }
        }

        async function submitOrder() {
            if(!window.PizzaCart) return;

            // Lấy items theo mode
            const cart = CHECKOUT_ITEMS;
            if(cart.length === 0) {
                alert('Không có sản phẩm để thanh toán!');
                return;
            }
            tempReviewItems = [...cart]; // Lưu lại cho bước 3


            // Validate card fields nếu đang ở tab Card
            const paymentMode = document.getElementById('mainPaymentMethod')?.value || '';
            if (paymentMode === 'card') {
                const cardFields = [
                    { id: 'card-name',   errId: 'err-card-name',   msg: 'Vui lòng nhập tên chủ thẻ.' },
                    { id: 'card-number', errId: 'err-card-number', msg: 'Vui lòng nhập số thẻ.' },
                    { id: 'card-expiry', errId: 'err-card-expiry', msg: 'Vui lòng nhập ngày hết hạn.' },
                    { id: 'card-cvv',    errId: 'err-card-cvv',    msg: 'Vui lòng nhập CVV.' },
                ];
                let cardError = false;
                // Xóa lỗi cũ trước
                cardFields.forEach(f => {
                    const el = document.getElementById(f.id);
                    if (el) clearFieldError(el, f.errId);
                });
                // Validate ngược lại để lỗi đầu tiên được focus
                [...cardFields].reverse().forEach(f => {
                    const el = document.getElementById(f.id);
                    if (el && !el.value.trim()) {
                        showFieldError(el, f.errId, f.msg);
                        cardError = true;
                    }
                });
                if (cardError) {
                    const firstErr = document.querySelector('#panel-card .input-error');
                    if (firstErr) firstErr.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    return;
                }
            }

            // Gom địa chỉ giao hàng
            const fullName = document.getElementById('fullName')?.value || '';
            const phone    = document.getElementById('phone')?.value    || '';
            const address  = document.getElementById('address')?.value  || '';
            const addrText = `${fullName} - ${phone} - ${address}`;

            const paymentMethod = document.getElementById('mainPaymentMethod')?.value || 'COD';
            const voucherCode   = document.getElementById('hiddenVoucherCode')?.value || '';

            // Lấy token CSRF
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

            // Disable nút để tránh double click
            const btn = document.getElementById('btnActionFlow');
            btn.disabled = true;
            btn.innerHTML = '<span class="material-symbols-outlined" style="animation:spin 1s linear infinite;display:inline-block;">progress_activity</span> Đang xử lý...';

            try {
                const formData = new FormData();
                formData.append('__RequestVerificationToken', token);
                formData.append('paymentMethod', paymentMethod);
                formData.append('voucherCode', voucherCode);
                formData.append('cartJson', JSON.stringify(cart));
                formData.append('shippingAddress', addrText);

                const res = await fetch('/Customer/PlaceOrder', {
                    method: 'POST',
                    body: formData
                });

                const data = await res.json();

                if (data.success) {
                    if (isBuyNowCheckout) {
                        // Chế độ mua ngay: chỉ xóa buynow_item
                        sessionStorage.removeItem('buynow_item');
                    } else {
                        // Xóa giỏ hàng localStorage
                        window.localStorage.removeItem('pizzadeli_cart');
                        if(window.PizzaCart && window.PizzaCart.clearCart) window.PizzaCart.clearCart();
                    }

                    // Hiện popup thành công
                    document.getElementById('successOrderCode').textContent = 'Mã đơn: #' + data.orderId;
                    const modal = document.getElementById('orderSuccessModal');
                    modal.style.display = 'flex';
                } else {
                    alert(data.message || 'Đặt hàng thất bại. Vui lòng thử lại!');
                    btn.disabled = false;
                    btn.innerHTML = 'Xác nhận <span class="material-symbols-outlined">check_circle</span>';
                }
            } catch(e) {
                console.error(e);
                alert('Lỗi kết nối. Vui lòng thử lại!');
                btn.disabled = false;
                btn.innerHTML = 'Xác nhận <span class="material-symbols-outlined">check_circle</span>';
            }
        }

        function goToReviews() {
            // Đóng Modal
            const modal = document.getElementById('orderSuccessModal');
            if (modal) modal.style.display = 'none';

            window.localStorage.removeItem('pizzadeli_cart');

            // Đổi UI sang Bước 3
            const payContent = document.getElementById('step-payment-content');
            if (payContent) payContent.style.display = 'none';
            
            const shipContent = document.getElementById('step-shipping-content');
            if (shipContent) shipContent.style.display = 'none';
            
            const reviewContent = document.getElementById('step-review-content');
            if (reviewContent) reviewContent.style.display = 'block';

            // Cập nhật thanh Stepper
            const stepReview = document.getElementById('stepperReview');
            if (stepReview) stepReview.classList.add('active');
            
            const stepSubtle = document.getElementById('stepperSubtitle');
            if (stepSubtle) stepSubtle.textContent = 'Bước 3 trong 3: Đánh giá sản phẩm của bạn';

            // Ẩn các nút hành động
            const btnActionFlow = document.getElementById('btnActionFlow');
            if (btnActionFlow) btnActionFlow.style.display = 'none';
            
            const voucherBox = document.getElementById('step-voucher-box');
            if (voucherBox) voucherBox.style.display = 'none';
            
            const btnGoBack = document.getElementById('btnGoBack');
            if (btnGoBack) btnGoBack.style.display = 'none';
            
            const btnHomeBack = document.getElementById('btnHomeBack');
            if (btnHomeBack) btnHomeBack.style.display = 'none';

            // HIện Đặt lại đơn, ẩn đặt thêm món (vì chỉ bước 3 mới có Đặt lại đơn trên Tóm tắt)
            const btnSidebarAddMore = document.getElementById('btnSidebarAddMore');
            if (btnSidebarAddMore) btnSidebarAddMore.style.display = 'none';

            const btnSidebarReorder = document.getElementById('btnSidebarReorder');
            if (btnSidebarReorder) btnSidebarReorder.style.display = 'inline-flex';

            currentStep = 3;
            
            // Xóa rỗng danh sách tổng kết giỏ hàng ở cột phải Sidebar
            const checkoutItemsList = document.getElementById('checkoutItemsList');
            if (checkoutItemsList) checkoutItemsList.innerHTML = '<p style="text-align:center; padding: 2rem;">Thanh toán thành công.</p>';

            // Load rỗng lại UI của Cart
            if (window.PizzaCart && window.PizzaCart.saveCart) {
                window.PizzaCart.saveCart([]);
                window.PizzaCart.renderCartDrawer();
            }

            // Render giao diện thẻ đánh giá
            buildReviewItems();
            attachStarRating();

            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
        
        function reorderLatest() {
            if (!confirm('Bạn có chắc muốn làm mới giỏ hàng bằng đơn hàng gần đây nhất của mình không?')) return;
            
            fetch('/Customer/GetLatestOrder')
            .then(res => res.json())
            .then(data => {
                if (data.success && data.items && data.items.length > 0) {
                    if (window.PizzaCart) {
                        window.PizzaCart.saveCart(data.items);
                        alert('Đã tải lại đơn hàng gần nhất thành công!');
                        // Chuyển hướng về trang chủ addmore=1 hoặc load lại chính trang Checkout.
                        // Bắt buộc bỏ param ?mode=buynow nếu đang có
                        window.location.href = '/Customer/Checkout';
                    }
                } else {
                    alert(data.message || 'Lỗi khi lấy thông tin đơn hàng cũ.');
                }
            })
            .catch(err => {
                alert('Có lỗi mạng khi truy xuất đơn hàng! Vui lòng thử lại.');
                console.error(err);
            });
        }
    </script>
}

