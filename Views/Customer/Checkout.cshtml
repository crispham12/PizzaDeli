                                                    <span style="font-size:0.78rem; color:#78350f; font-weight:600;">Đơn hàng sẽ được xác nhận sau khi chúng tôi nhận được thanh toán.</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Panel: Bank -->
                                <div class="payment-panel" id="panel-bank">
                                    <div style="border:1.5px solid #a855f722; border-radius:16px; background:linear-gradient(135deg,#fcf4ff 0%,#f3e8ff 100%); overflow:hidden;">
                                        <div style="background:#7e22ce; padding:0.75rem 1.25rem; display:flex; align-items:center; gap:0.6rem;">
                                            <span class="material-symbols-outlined" style="color:#fff; font-size:1.25rem;">account_balance</span>
                                            <span style="color:#fff; font-weight:700; font-size:0.95rem;">Chuyển khoản TP Bank</span>
                                        </div>
                                        <div style="padding:1.5rem; display:flex; flex-wrap:wrap; gap:1.5rem; align-items:flex-start;">
                                            <!-- QR Code -->
                                            <div style="flex-shrink:0; text-align:center;">
                                                <div style="width:140px; height:140px; background:#fff; border-radius:12px; border:1px solid #d8b4fe; display:flex; align-items:center; justify-content:center; overflow:hidden; box-shadow:0 2px 8px rgba(126,34,206,0.10);">
                                                    <img id="bank-qr-img" src="" alt="TP Bank QR" style="width:128px;height:128px;object-fit:contain;" />
                                                </div>
                                                <p style="font-size:0.72rem; color:#64748b; margin-top:0.5rem; font-weight:600;">Quét mã VietQR</p>
                                            </div>
