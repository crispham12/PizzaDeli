@section Scripts {
    <script>
        function toggleCustomerDropdown(e) {
            if(e) e.stopPropagation();
            var menu = document.getElementById('customerDropdownMenu');
            if (menu) menu.classList.toggle('show');
        }
        window.addEventListener('click', function(e) {
            var menu = document.getElementById('customerDropdownMenu');
            var wrapper = document.getElementById('customerDropdownWrapper');
            if (menu && menu.classList.contains('show') && wrapper && !wrapper.contains(e.target)) {
                menu.classList.remove('show');
            }
        });
        
        // Custom Builder Logic
        const MAX_TOPPINGS = 4;
        
        function formatPrice(num) {
            return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ".") + '₫';
        }

        function updateReceipt() {
            // Get selected size
            const activeSize = document.querySelector('.size-card.active');
            const sizeName = activeSize ? activeSize.dataset.name : '';
            const sizePrice = activeSize ? parseFloat(activeSize.dataset.price) : 0;

            // Get selected crust
            const activeCrust = document.querySelector('.crust-option.active');
            const crustName = activeCrust ? activeCrust.dataset.name : '';
            const crustPrice = activeCrust ? parseFloat(activeCrust.dataset.price) : 0;

            // Get selected cheese
            const cheeseName = document.getElementById('cheeseSelect').value;

            // Get selected toppings
            const activeToppings = document.querySelectorAll('.topping-card.active');
            let toppingsHtml = '';
            let toppingsTotal = 0;

            activeToppings.forEach(t => {
                const name = t.dataset.name;
                const price = parseFloat(t.dataset.price);
                toppingsTotal += price;
                toppingsHtml += `
                    <div class="r-item">
                        <span class="r-item-name">+ ${name}</span>
                        <span class="r-item-price">${formatPrice(price)}</span>
                    </div>
                `;
            });

            // Update DOM
            document.getElementById('r-size-name').textContent = 'Kích cỡ: ' + sizeName;
            document.getElementById('r-size-price').textContent = formatPrice(sizePrice);

            document.getElementById('r-crust-name').textContent = 'Đế bánh: ' + crustName;
            document.getElementById('r-crust-price').textContent = crustPrice > 0 ? '+' + formatPrice(crustPrice) : 'BAO GỒM';

            document.getElementById('r-cheese-name').textContent = 'Phô mai: ' + cheeseName;

            document.getElementById('r-toppings-container').innerHTML = toppingsHtml;

            // Total
            const total = sizePrice + crustPrice + toppingsTotal;
            document.getElementById('r-total-price').textContent = formatPrice(total);
        }

        // Event listeners
        document.querySelectorAll('.size-card').forEach(card => {
            card.addEventListener('click', function() {
                document.querySelectorAll('.size-card').forEach(c => c.classList.remove('active'));
                this.classList.add('active');
                updateReceipt();
            });
        });
        
        document.querySelectorAll('.crust-option').forEach(opt => {
            opt.addEventListener('click', function() {
                document.querySelectorAll('.crust-option').forEach(c => c.classList.remove('active'));
                this.classList.add('active');
                updateReceipt();
            });
        });

        document.getElementById('cheeseSelect').addEventListener('change', updateReceipt);

        document.querySelectorAll('.topping-card').forEach(card => {
            card.addEventListener('click', function() {
                const isActive = this.classList.contains('active');
                const currentActiveCount = document.querySelectorAll('.topping-card.active').length;

                if (!isActive && currentActiveCount >= MAX_TOPPINGS) {
                    alert('Bạn chỉ được chọn tối đa ' + MAX_TOPPINGS + ' topping thủ công!');
                    return;
                }

                this.classList.toggle('active');
                updateReceipt();
            });
        });

        // Initial calculation
        updateReceipt();

        function toggleToppings(btn) {
            const extraToppings = document.querySelectorAll('.extra-topping');
            if (extraToppings.length === 0) return;
            const isHidden = extraToppings[0].classList.contains('d-none');
            if (isHidden) {
                extraToppings.forEach(t => t.classList.remove('d-none'));
                btn.innerHTML = `Thu gọn <span class="material-symbols-outlined" style="font-size:1.1rem;">expand_less</span>`;
            } else {
                extraToppings.forEach(t => t.classList.add('d-none'));
                btn.innerHTML = `Xem thêm <span class="material-symbols-outlined" style="font-size:1.1rem;">expand_more</span>`;
            }
        }

        function getCustomPizzaData() {
            // 1. Lấy thông tin Kích cỡ đã chọn (Size)
            const activeSize = document.querySelector('.size-card.active');
            const sizeName = activeSize ? activeSize.dataset.name : '';
            const sizePrice = activeSize ? parseFloat(activeSize.dataset.price) : 0;

            // 2. Lấy thông tin Đế bánh đã chọn (Crust)
            const activeCrust = document.querySelector('.crust-option.active');
            const crustName = activeCrust ? activeCrust.dataset.name : '';
            const crustPrice = activeCrust ? parseFloat(activeCrust.dataset.price) : 0;

            // 3. Lấy thông tin Phô mai đã chọn (Cheese)
            const cheeseName = document.getElementById('cheeseSelect').value;

            // 4. Lấy danh sách Topping đã chọn
            const activeToppings = document.querySelectorAll('.topping-card.active');
            let toppingsTotal = 0;
            const toppingNames = [];
            activeToppings.forEach(t => {
                toppingNames.push(t.dataset.name);
                toppingsTotal += parseFloat(t.dataset.price); // Cộng dồn giá topping
            });

            // 5. Cộng tổng tiền của toàn bộ Pizza
            const total = sizePrice + crustPrice + toppingsTotal;
            
            // 6. Gộp tên thành chuỗi định dạng đặc biệt để Backend (OrderService) có thể parse và trừ tồn kho
            let finalName = `Pizza Tự Chọn (${sizeName}, ${crustName}, ${cheeseName})`;
            if(toppingNames.length > 0) finalName += ` + ${toppingNames.join(', ')}`;

            return {
                id: 'CUSTOM-' + Date.now(), // Tiền tố CUSTOM- giúp backend nhận diện đây là sản phẩm ảo cần khởi tạo
                name: finalName,
                price: total,
                image: '/images/auth-bg.jpg', // Default image or fallback
                quantity: 1
            };
        }

        // Sự kiện: Thêm Pizza tự chọn vào giỏ hàng
        document.querySelector('.btn-cart-icon').addEventListener('click', function() {
            const pizza = getCustomPizzaData();
            if(window.PizzaCart) {
                window.PizzaCart.addToCart(pizza); // Lưu vào LocalStorage
            }
        });

        // Sự kiện: Bấm thanh toán ngay
        document.querySelector('.btn-checkout').addEventListener('click', function() {
            const pizza = getCustomPizzaData();
            if(window.PizzaCart) {
                const cart = window.PizzaCart.getCart();
                cart.push(pizza);
                window.PizzaCart.saveCart(cart); // Cập nhật LocalStorage
                window.location.href = '/Customer/Checkout'; // Chuyển thẳng sang trang thanh toán
            }
        });
    </script>
}
