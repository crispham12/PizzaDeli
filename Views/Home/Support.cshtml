@{
    ViewData["Title"] = "Liên hệ Hỗ trợ";
    var _role  = Context.Session.GetString("USER_ROLE");
    var _name  = Context.Session.GetString("USER_NAME");
    var _auth  = !string.IsNullOrEmpty(_role);
}

@section Styles {
    <style>
        .support-page-wrap {
            background-color: #f7f3f0;
            padding: 4rem 1rem 6rem;
            min-height: calc(100vh - 400px); 
        }
        .support-header {
            max-width: 1000px;
            margin: 0 auto 3rem auto;
            text-align: left;
        }
        .support-title {
            color: #1a1a1a;
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 0.75rem;
        }
        .support-subtitle {
            color: #6b7280;
            font-size: 1.05rem;
            line-height: 1.5;
            max-width: 700px;
        }
        .support-grid {
            max-width: 1000px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1.2fr 1fr;
            gap: 2rem;
        }
        .support-card {
            background-color: #ffffff;
            border-radius: 16px;
            padding: 2rem;
            box-shadow: 0 4px 20px rgba(0,0,0,0.03);
            border: 1px solid #f0ede9;
        }
        .card-title {
            font-size: 1.25rem;
            font-weight: 700;
            color: #1a1a1a;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .form-group {
            margin-bottom: 1.25rem;
        }
        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }
        .form-label {
            display: block;
            font-size: 0.75rem;
            font-weight: 700;
            color: #4a2c22;
            text-transform: uppercase;
            margin-bottom: 0.5rem;
            letter-spacing: 0.05em;
        }
        .form-control {
            width: 100%;
            background-color: #f9fafb;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            padding: 0.75rem 1rem;
            font-size: 0.95rem;
            color: #1f2937;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .form-control:focus {
            border-color: #4a2c22;
            box-shadow: 0 0 0 3px rgba(74, 44, 34, 0.1);
        }
        .form-control::placeholder {
            color: #9ca3af;
        }
        textarea.form-control {
            resize: vertical;
            min-height: 120px;
        }
        .btn-submit {
            background-color: #4a2c22;
            color: #ffffff;
            border: none;
            padding: 0.875rem 1.5rem;
            border-radius: 99px;
            font-size: 0.95rem;
            font-weight: 700;
            cursor: pointer;
            transition: background-color 0.2s;
            display: inline-block;
        }
        .btn-submit:hover {
            background-color: #3d231b;
        }

        /* FAQ Styles */
        .faq-item {
            border-bottom: 1px solid #f3f4f6;
            padding: 1rem 0;
        }
        .faq-item:first-of-type {
            padding-top: 0;
        }
        .faq-question {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.95rem;
            font-weight: 600;
            color: #374151;
            cursor: pointer;
        }
        .faq-question span.material-symbols-outlined {
            color: #9ca3af;
            font-size: 1.25rem;
        }
        .btn-outline {
            display: block;
            width: 100%;
            text-align: center;
            border: 1px solid #e5e7eb;
            background-color: transparent;
            color: #374151;
            padding: 0.75rem;
            border-radius: 8px;
            font-weight: 600;
            font-size: 0.9rem;
            margin-top: 1.5rem;
            cursor: pointer;
            text-decoration: none;
            transition: background-color 0.2s;
        }
        .btn-outline:hover {
            background-color: #f9fafb;
        }

        /* Contact Info Cards */
        .contact-info-wrap {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin-top: 2rem;
        }
        .info-card {
            background-color: #f9fafb;
            border-radius: 12px;
            padding: 1.25rem;
        }
        .info-card .icon-wrap {
            margin-bottom: 0.5rem;
        }
        .info-card .icon-wrap span {
            color: #4a2c22;
        }
        .info-label {
            font-size: 0.75rem;
            font-weight: 700;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 0.25rem;
        }
        .info-value {
            font-size: 1.1rem;
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 0.25rem;
        }
        .info-desc {
            font-size: 0.75rem;
            color: #9ca3af;
            text-transform: uppercase;
        }

        /* Nav Dropdown CSS */
        .btn-profile-dropdown {
            background-color: #f4ede6;
            color: #1f2937;
            border: none;
            padding: 0.5rem 1rem;
            border-radius: 99px;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-weight: 700;
            font-size: 0.9rem;
            cursor: pointer;
            transition: opacity 0.2s;
        }
        .btn-profile-dropdown:hover { opacity: 0.9; }
        .customer-dropdown-menu {
            display: none;
            position: absolute;
            top: calc(100% + 10px);
            right: 0;
            background: #ffffff;
            color: #1f2937;
            border-radius: 20px;
            width: 300px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
            z-index: 100;
            overflow: hidden;
            flex-direction: column;
            padding: 0.5rem 0;
        }
        .customer-dropdown-menu.show { display: flex; animation: fadeIn 0.2s ease; }
        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .c-dropdown-item {
            display: flex; align-items: center; gap: 16px;
            padding: 12px 20px; text-decoration: none; color: #374151; transition: background 0.15s;
        }
        .c-dropdown-item.border-bt { border-bottom: 1px solid #f3f4f6; padding-bottom: 16px; margin-bottom: 4px; }
        .c-dropdown-item:hover { background: #f9fafb; color: #1f2937; }
        .c-item-icon-wrap {
            width: 44px; height: 44px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0;
        }
        .c-item-icon-wrap.primary { background: #e1d3c1; color: #533e38; }
        .c-item-icon-wrap.danger-bg { background: #eabfb9; }
        .c-item-text { display: flex; flex-direction: column; }
        .c-item-title { font-weight: 700; font-size: 1.05rem; line-height: 1.2; color: #533e38; }
        .c-item-desc { font-size: 0.85rem; color: #8c837f; margin-top: 4px; }
        
        .nav-links a.active-nav { color: #c45c2e; font-weight: 800; }
        
        @@media (max-width: 768px) {
            .support-grid {
                grid-template-columns: 1fr;
            }
            .form-row {
                grid-template-columns: 1fr;
            }
            .contact-info-wrap {
                grid-template-columns: 1fr;
            }
            .support-title {
                font-size: 2rem;
            }
        }
    </style>
}

<div class="layout-container">

    <!-- ===================== HEADER ===================== -->
    <header class="site-header">
        <div class="container nav-inner">

            <!-- Left: Brand + Nav Links -->
            <div class="nav-left">
                <div class="brand">
                    <span class="material-symbols-outlined">local_pizza</span>
                    <a asp-controller="Home" asp-action="Index" style="text-decoration:none;">
                        <h2 class="brand-name">PizzaDeli</h2>
                    </a>
                </div>
                <nav class="nav-links">
                    <a asp-controller="Home" asp-action="Menu">Thực đơn</a>
                    <a asp-controller="Home" asp-action="Promotions">Khuyến mãi</a>
                    <a asp-controller="Home" asp-action="Scan">Quét ảnh</a>
                    <a asp-controller="Home" asp-action="Support" class="active-nav">Liên hệ</a>
                </nav>
            </div>

            <!-- Right: Actions -->
            <div class="nav-actions">
                @if (_auth)
                {
                    @if (_role == "Admin")
                    {
                        <a asp-controller="Admin" asp-action="Dashboard" class="btn-profile">
                            <span class="material-symbols-outlined">admin_panel_settings</span>
                            <span class="btn-profile-text">Admin</span>
                        </a>
                    }
                    else if (_role == "Staff")
                    {
                        <a asp-controller="Staff" asp-action="Orders" class="btn-profile">
                            <span class="material-symbols-outlined">badge</span>
                            <span class="btn-profile-text">Nhân viên</span>
                        </a>
                    }
                    else
                    {
                        <div style="position:relative;" id="customerDropdownWrapper">
                            <button class="btn-profile-dropdown" onclick="toggleCustomerDropdown(event)">
                                <span class="material-symbols-outlined">person</span>
                                <span>@_name</span>
                                <span class="material-symbols-outlined" style="font-size:1.1rem;">keyboard_arrow_down</span>
                            </button>
                            <div class="customer-dropdown-menu" id="customerDropdownMenu">
                                <a href="/Customer/Orders" class="c-dropdown-item">
                                    <div class="c-item-icon-wrap primary">
                                        <span class="material-symbols-outlined">receipt_long</span>
                                    </div>
                                    <div class="c-item-text">
                                        <div class="c-item-title">Đơn hàng của tôi</div>
                                        <div class="c-item-desc">Theo dõi &amp; quản lý đơn hàng</div>
                                    </div>
                                </a>
                                <a asp-controller="Customer" asp-action="Profile" class="c-dropdown-item">
                                    <div class="c-item-icon-wrap primary">
                                        <span class="material-symbols-outlined">person</span>
                                    </div>
                                    <div class="c-item-text">
                                        <div class="c-item-title">Thông tin cá nhân</div>
                                        <div class="c-item-desc">Quản lý tài khoản của bạn</div>
                                    </div>
                                </a>
                                <a asp-controller="Customer" asp-action="ChangePassword" class="c-dropdown-item">
                                    <div class="c-item-icon-wrap primary">
                                        <span class="material-symbols-outlined">lock_reset</span>
                                    </div>
                                    <div class="c-item-text">
                                        <div class="c-item-title">Đổi mật khẩu</div>
                                        <div class="c-item-desc">Bảo mật tài khoản</div>
                                    </div>
                                </a>
                                <a asp-controller="Home" asp-action="Response" class="c-dropdown-item">
                                    <div class="c-item-icon-wrap primary">
                                        <span class="material-symbols-outlined c-item-icon">support_agent</span>
                                    </div>
                                    <div class="c-item-text">
                                        <div class="c-item-title">Hồi đáp vấn đề</div>
                                        <div class="c-item-desc">Liên hệ hỗ trợ</div>
                                    </div>
                                </a>
                                <a asp-controller="Account" asp-action="Logout" class="c-dropdown-item logout-item">
                                    <div class="c-item-icon-wrap danger-bg">
                                        <span class="material-symbols-outlined" style="color:#782a2a; transform: scaleX(-1);">logout</span>
                                    </div>
                                    <div class="c-item-text" style="display:flex; align-items:center;">
                                        <div class="c-item-title" style="color:#782a2a; font-size: 1.1rem; margin:0;">Đăng xuất</div>
                                    </div>
                                </a>
                            </div>
                        </div>
                        <a href="javascript:void(0)" onclick="window.PizzaCart && window.PizzaCart.openCartDrawer()" class="btn-cart" aria-label="Giỏ hàng">
                            <span class="material-symbols-outlined">shopping_cart</span>
                            <span class="cart-badge" id="cart-count">0</span>
                        </a>
                    }
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn-profile">
                        <span class="material-symbols-outlined">login</span>
                        <span class="btn-profile-text">Đăng nhập</span>
                    </a>
                    <a asp-controller="Account" asp-action="Register" class="btn-cart" style="text-decoration:none; padding: 0.5rem 1rem; font-size:0.875rem; font-weight:700;">
                        Đăng ký
                    </a>
                }
            </div>
        </div>
    </header>

    <div class="support-page-wrap">
        <div class="support-header">
            <h1 class="support-title">Liên hệ hỗ trợ</h1>
            <p class="support-subtitle">Đội ngũ của chúng tôi luôn sẵn sàng hỗ trợ bạn với bất kỳ câu hỏi nào về đơn hàng, thực đơn hoặc các dịch vụ khác của PizzaDeli.</p>
        </div>

        <div class="support-grid">
            <!-- Left: Contact Form -->
            <div class="support-card">
                <h2 class="card-title">Gửi tin nhắn cho chúng tôi</h2>
                @if (TempData["SuccessMessage"] != null)
                {
                    <div style="background-color: #d1fae5; color: #065f46; padding: 1rem; border-radius: 8px; margin-bottom: 1rem; font-weight: 600;">
                        @TempData["SuccessMessage"]
                    </div>
                }
                <form asp-controller="Home" asp-action="Support" method="post">
                    @Html.AntiForgeryToken()
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">HỌ VÀ TÊN</label>
                            <input type="text" name="FullName" class="form-control" placeholder="Nguyễn Văn A" value="@_name" required />
                        </div>
                        <div class="form-group">
                            <label class="form-label">MÃ ĐƠN HÀNG</label>
                            <input type="text" class="form-control" value="@ViewBag.NextCode" style="background-color: #f1f5f9; cursor: not-allowed; color: #64748b; font-weight: 600;" readonly />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">SỐ ĐIỆN THOẠI</label>
                            <input type="text" name="Phone" class="form-control" placeholder="090 123 4567" required />
                        </div>
                        <div class="form-group">
                            <label class="form-label">ĐỊA CHỈ</label>
                            <input type="text" name="Address" class="form-control" placeholder="123 Phố Huế..." required />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">LOẠI VẤN ĐỀ</label>
                        <select name="IssueType" class="form-control" style="appearance: none; background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%239ca3af%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E'); background-repeat: no-repeat; background-position: right 1rem top 50%; background-size: 0.65rem auto;">
                            <option>Trạng thái đơn hàng</option>
                            <option>Hỗ trợ sản phẩm</option>
                            <option>Phản ánh dịch vụ</option>
                            <option>Vấn đề thanh toán</option>
                            <option>Khác</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">TIN NHẮN CỦA BẠN</label>
                        <textarea name="Message" class="form-control" placeholder="Mô tả chi tiết vấn đề của bạn..." required></textarea>
                    </div>
                    <button type="submit" class="btn-submit">Gửi yêu cầu hỗ trợ</button>
                </form>
            </div>

            <!-- Right: FAQ & Contact Info -->
            <div>
                <!-- FAQ section -->
                <div class="support-card" style="margin-bottom: 2rem; padding: 1.5rem 2rem;">
                    <h2 class="card-title">
                        <span class="material-symbols-outlined" style="color:#78350f;">help</span>
                        Câu hỏi thường gặp
                    </h2>
                    <div class="faq-list">
                        <div class="faq-item">
                            <div class="faq-question">
                                <span>Thời gian giao hàng trung bình là bao lâu?</span>
                                <span class="material-symbols-outlined">expand_more</span>
                            </div>
                        </div>
                        <div class="faq-item">
                            <div class="faq-question">
                                <span>Tôi có thể thay đổi địa chỉ sau khi đặt hàng không?</span>
                                <span class="material-symbols-outlined">expand_more</span>
                            </div>
                        </div>
                        <div class="faq-item">
                            <div class="faq-question">
                                <span>Làm thế nào để áp dụng mã giảm giá?</span>
                                <span class="material-symbols-outlined">expand_more</span>
                            </div>
                        </div>
                        <div class="faq-item">
                            <div class="faq-question">
                                <span>PizzaDeli có các món chay không?</span>
                                <span class="material-symbols-outlined">expand_more</span>
                            </div>
                        </div>
                        <div class="faq-item" style="border-bottom:none;">
                            <div class="faq-question">
                                <span>Chính sách hoàn tiền của PizzaDeli như thế nào?</span>
                                <span class="material-symbols-outlined">expand_more</span>
                            </div>
                        </div>
                    </div>
                    <a href="#" class="btn-outline">Xem tất cả câu hỏi</a>
                </div>

                <!-- Info Cards -->
                <div class="contact-info-wrap">
                    <div class="info-card">
                        <div class="icon-wrap">
                            <span class="material-symbols-outlined">call</span>
                        </div>
                        <div class="info-label">ĐIỆN THOẠI</div>
                        <div class="info-value">0346765950</div>
                        <div class="info-desc">24/7 SUPPORT</div>
                    </div>
                    <div class="info-card">
                        <div class="icon-wrap">
                            <span class="material-symbols-outlined">mail</span>
                        </div>
                        <div class="info-label">EMAIL</div>
                        <div class="info-value">phamanhkhoa56789@gmail.vn</div>
                        <div class="info-desc">PHẢN HỒI < 2H</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- ===================== FOOTER ===================== -->
    <footer class="site-footer" id="footer">
        <div class="container">
            <div class="footer-grid">

                <!-- Brand -->
                <div class="footer-brand">
                    <div class="footer-brand-row">
                        <span class="material-symbols-outlined">local_pizza</span>
                        <span class="footer-brand-name">PizzaDeli</span>
                    </div>
                    <p class="footer-desc">
                        Mang đến hương vị pizza nướng chính thống từ lò gỗ đến bàn ăn của bạn. Nguyên liệu chất lượng, chế biến với niềm đam mê.
                    </p>
                    <div class="social-links">
                        <a href="#" class="social-link" aria-label="Share">
                            <span class="material-symbols-outlined">share</span>
                        </a>
                        <a href="#" class="social-link" aria-label="Website">
                            <span class="material-symbols-outlined">public</span>
                        </a>
                        <a href="#" class="social-link" aria-label="Instagram">
                            <span class="material-symbols-outlined">camera</span>
                        </a>
                    </div>
                </div>

                <!-- Quick Links -->
                <div class="footer-col">
                    <h4>Liên kết nhanh</h4>
                    <ul>
                        <li><a href="#">Về chúng tôi</a></li>
                        <li><a href="/Home/Menu">Thực đơn</a></li>
                        <li><a href="#">Thẻ quà</a></li>
                        <li><a href="#">Tuyển dụng</a></li>
                    </ul>
                </div>

                <!-- Support -->
                <div class="footer-col">
                    <h4>Hỗ trợ</h4>
                    <ul>
                        <li><a href="#">Hỏi đáp</a></li>
                        <li><a href="#">Theo dõi đơn hàng</a></li>
                        <li><a href="#">Chính sách riêng tư</a></li>
                        <li><a href="#">Thỏa thuận dịch vụ</a></li>
                    </ul>
                </div>

                <!-- Contact -->
                <div class="footer-col">
                    <h4>Liên hệ</h4>
                    <ul>
                        <li class="footer-contact-item">
                            <span class="material-symbols-outlined">call</span>
                            +84 346765950
                        </li>
                        <li class="footer-contact-item">
                            <span class="material-symbols-outlined">mail</span>
                            phamanhkhoa56789@gmail.com
                        </li>
                        <li class="footer-contact-item">
                            <span class="material-symbols-outlined">location_on</span>
                            137 Nguyễn Thị Thập
                        </li>
                    </ul>
                </div>

            </div>

            <!-- Footer Bottom -->
            <div class="footer-bottom">
                <p>&copy; 2026 PizzaDeli. Toàn quyền bảo lưu.</p>
                <div class="footer-bottom-links">
                    <a href="#">Cookie</a>
                    <a href="#">Bảo mật</a>
                    <a href="#">Sơ đồ trang</a>
                </div>
            </div>
        </div>
    </footer>

</div>

@section Scripts {
    <script>
        function toggleCustomerDropdown(e) {
            if(e) e.stopPropagation();
            var menu = document.getElementById('customerDropdownMenu');
            if (menu) menu.classList.toggle('show');
        }
        window.addEventListener('click', function(e) {
            var menu = document.getElementById('customerDropdownMenu');
            var wrapper = document.getElementById('customerDropdownWrapper');
            if (menu && menu.classList.contains('show') && wrapper && !wrapper.contains(e.target)) {
                menu.classList.remove('show');
            }
        });
    </script>
}
