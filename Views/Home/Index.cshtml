@model List<PizzaDeli.Models.Category>
@{
    ViewData["Title"] = "PizzaDeli - Authentic Wood-Fired Pizza";
    var isAddMore = Context.Request.Query["addmore"] == "1";
}

@section Styles {
    <style>
        /* Customer Dropdown Styles */
        .btn-profile-dropdown {
            background-color: #f4ede6; /* bg nâu nhạt */
            color: #1f2937; /* text chữ đen */
            border: none;
            padding: 0.5rem 1rem;
            border-radius: 99px;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-weight: 700;
            font-size: 0.9rem;
            cursor: pointer;
            transition: opacity 0.2s;
        }
        .btn-profile-dropdown:hover {
            opacity: 0.9;
        }
        .customer-dropdown-menu {
            display: none;
            position: absolute;
            top: calc(100% + 10px);
            right: 0;
            background: #ffffff;
            color: #1f2937;
            border-radius: 20px;
            width: 300px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
            z-index: 100;
            overflow: hidden;
            flex-direction: column;
            padding: 0.5rem 0;
        }
        .customer-dropdown-menu.show {
            display: flex;
            animation: fadeIn 0.2s ease;
        }
        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .c-dropdown-item {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 12px 20px;
            text-decoration: none;
            color: #374151;
            transition: background 0.15s;
        }
        .c-dropdown-item.border-bt {
            border-bottom: 1px solid #f3f4f6;
            padding-bottom: 16px;
            margin-bottom: 4px;
        }
        .c-dropdown-item:hover {
            background: #f9fafb;
            color: #1f2937;
        }
        .c-item-icon-wrap {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        .c-item-icon-wrap.primary {
            background: #e1d3c1;
            color: #533e38;
        }
        .c-item-icon-wrap.danger-bg {
            background: #eabfb9;
        }
        .c-item-text {
            display: flex;
            flex-direction: column;
        }
        .c-item-title {
            font-weight: 700;
            font-size: 1.05rem;
            line-height: 1.2;
            color: #533e38;
        }
        .c-item-title.danger {
            color: #ef4444;
        }
        .c-item-desc {
            font-size: 0.85rem;
            color: #8c837f;
            margin-top: 4px;
        }
        /* Custom Pagination */
        .c-pagination {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 12px;
            margin-top: 2.5rem;
            margin-bottom: 2rem;
        }
        .c-page-link {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            color: #374151;
            background: #fff;
            border: 1px solid #e5e7eb;
            font-weight: 700;
            font-size: 1.1rem;
            transition: all 0.2s;
            box-shadow: 0 2px 5px rgba(0,0,0,0.02);
        }
        .c-page-link:hover {
            border-color: #d1d5db;
            background: #f9fafb;
            color: #374151;
        }
        .c-page-active {
            background: #5c3d2e;
            color: #fff;
            border-color: #5c3d2e;
        }
        .c-page-active:hover {
            background: #5c3d2e;
            color: #fff;
        }
        .c-page-active span {
            border-bottom: 2px solid #fff;
            padding-bottom: 1px;
            line-height: 1;
        }
        .c-page-icon {
            color: #3b82f6; /* icon blue mũi tên */
            font-weight: 600;
        }
        /* ---- Menu Grid Pagination ---- */
        .menu-paged-item.hidden-page {
            display: none !important;
        }
        .menu-pagination {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-top: 2rem;
            margin-bottom: 0.5rem;
        }
        .menu-pagination:empty { display: none; }
        .mpager-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 0.55rem 1.2rem;
            border-radius: 99px;
            border: 1.5px solid #e5e7eb;
            background: #fff;
            color: #374151;
            font-weight: 700;
            font-size: 0.92rem;
            cursor: pointer;
            transition: all 0.18s;
            box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        }
        .mpager-btn:hover:not(:disabled) {
            border-color: #5c3d2e;
            color: #5c3d2e;
            background: #fdf8f5;
            box-shadow: 0 4px 14px rgba(92,61,46,0.10);
        }
        .mpager-btn:disabled {
            opacity: 0.3;
            cursor: default;
        }
        .mpager-dots {
            display: flex;
            gap: 6px;
            align-items: center;
        }
        .mpager-dot {
            width: 8px; height: 8px;
            border-radius: 50%;
            background: #d1d5db;
            transition: background 0.2s, transform 0.2s;
            cursor: pointer;
        }
        .mpager-dot.active {
            background: #5c3d2e;
            transform: scale(1.35);
        }
        .mpager-info {
            font-size: 0.88rem;
            color: #9ca3af;
            font-weight: 600;
        }
    </style>
}

@section Scripts {
<script>
(function() {
    var PAGE_SIZE = 6;

    function initGridPagination() {
        document.querySelectorAll('.products-grid[data-cat-id]').forEach(function(grid) {
            var catId = grid.getAttribute('data-cat-id');
            var items = Array.from(grid.querySelectorAll('.menu-paged-item'));
            var total = items.length;
            if (total <= PAGE_SIZE) return; // no pagination needed

            var totalPages = Math.ceil(total / PAGE_SIZE);
            var currentPage = 0;

            function showPage(page) {
                currentPage = page;
                items.forEach(function(item, idx) {
                    var pageOfItem = Math.floor(idx / PAGE_SIZE);
                    if (pageOfItem === currentPage) {
                        item.classList.remove('hidden-page');
                    } else {
                        item.classList.add('hidden-page');
                    }
                });
                renderPager();
            }

            function renderPager() {
                var pager = document.getElementById('pager-' + catId);
                if (!pager) return;

                var prevDisabled = currentPage === 0 ? 'disabled' : '';
                var nextDisabled = currentPage === totalPages - 1 ? 'disabled' : '';

                var dots = '';
                for (var i = 0; i < totalPages; i++) {
                    dots += '<span class="mpager-dot' + (i === currentPage ? ' active' : '') + '" data-pg="' + i + '"></span>';
                }

                pager.innerHTML =
                    '<button class="mpager-btn" id="mprev-' + catId + '" ' + prevDisabled + '>'
                    + '<span class="material-symbols-outlined" style="font-size:1.1rem;">arrow_back</span> Trước'
                    + '</button>'
                    + '<div class="mpager-dots" id="mdots-' + catId + '">' + dots + '</div>'
                    + '<span class="mpager-info">' + (currentPage + 1) + ' / ' + totalPages + '</span>'
                    + '<button class="mpager-btn" id="mnext-' + catId + '" ' + nextDisabled + '>'
                    + 'Tiếp <span class="material-symbols-outlined" style="font-size:1.1rem;">arrow_forward</span>'
                    + '</button>';

                // Bind prev/next
                var prevBtn = document.getElementById('mprev-' + catId);
                var nextBtn = document.getElementById('mnext-' + catId);
                if (prevBtn) prevBtn.addEventListener('click', function() { if (currentPage > 0) showPage(currentPage - 1); });
                if (nextBtn) nextBtn.addEventListener('click', function() { if (currentPage < totalPages - 1) showPage(currentPage + 1); });

                // Bind dots
                var dotsEl = document.getElementById('mdots-' + catId);
                if (dotsEl) {
                    dotsEl.querySelectorAll('.mpager-dot').forEach(function(dot) {
                        dot.addEventListener('click', function() {
                            var pg = parseInt(this.getAttribute('data-pg'));
                            showPage(pg);
                        });
                    });
                }
            }

            showPage(0); // init
        });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initGridPagination);
    } else {
        initGridPagination();
    }
})();
</script>
}

<div class="layout-container">

    <!-- ===================== HEADER ===================== -->
    <header class="site-header">
        <div class="container nav-inner">

            <!-- Left: Brand + Nav Links -->
            <div class="nav-left">
                <div class="brand">
                    <span class="material-symbols-outlined">local_pizza</span>
                    <h2 class="brand-name">PizzaDeli</h2>
                </div>
                <nav class="nav-links">
                    <a asp-controller="Home" asp-action="Menu">Thực đơn</a>
                    <a asp-controller="Home" asp-action="Promotions">Khuyến mãi</a>
                    <a asp-controller="Home" asp-action="Scan">Quét ảnh</a>
                    <a asp-controller="Home" asp-action="Support">Liên hệ</a>
                </nav>
            </div>

            <!-- Center: Search Bar (desktop) -->
            <div class="search-wrapper">
                <div class="search-box">
                    <span class="material-symbols-outlined search-icon">search</span>
                    <input class="search-input" type="text" placeholder="Tìm pizza yêu thích của bạn..." />
                </div>
            </div>

            <!-- Right: Actions -->
            <div class="nav-actions">
                <!-- Mobile search toggle -->
                <button class="btn-icon btn-mobile-search" id="mobile-search-btn" aria-label="Search">
                    <span class="material-symbols-outlined">search</span>
                </button>

                @{
                    var _role  = Context.Session.GetString("USER_ROLE");
                    var _name  = Context.Session.GetString("USER_NAME");
                    var _auth  = !string.IsNullOrEmpty(_role);
                }

                @if (_auth)
                {
                    <!-- Đã đăng nhập -->
                    @if (_role == "Admin")
                    {
                        <a asp-controller="Admin" asp-action="Dashboard" class="btn-profile">
                            <span class="material-symbols-outlined">admin_panel_settings</span>
                            <span class="btn-profile-text">Admin</span>
                        </a>
                    }
                    else if (_role == "Staff")
                    {
                        <a asp-controller="Staff" asp-action="Orders" class="btn-profile">
                            <span class="material-symbols-outlined">badge</span>
                            <span class="btn-profile-text">Nhân viên</span>
                        </a>
                    }
                    else
                    {
                        <div style="position:relative;" id="customerDropdownWrapper">
                            <button class="btn-profile-dropdown" onclick="toggleCustomerDropdown(event)">
                                <span class="material-symbols-outlined">person</span>
                                <span>@_name</span>
                                <span class="material-symbols-outlined" style="font-size:1.1rem;">keyboard_arrow_down</span>
                            </button>
                            <div class="customer-dropdown-menu" id="customerDropdownMenu">
                                <a href="/Customer/Orders" class="c-dropdown-item">
                                    <div class="c-item-icon-wrap primary">
                                        <span class="material-symbols-outlined c-item-icon">receipt_long</span>
                                    </div>
                                    <div class="c-item-text">
                                        <div class="c-item-title">Đơn hàng của tôi</div>
                                        <div class="c-item-desc">Theo dõi & quản lý đơn hàng</div>
                                    </div>
                                </a>
                                <a asp-controller="Customer" asp-action="Profile" class="c-dropdown-item">
                                    <div class="c-item-icon-wrap primary">
                                        <span class="material-symbols-outlined c-item-icon">person</span>
                                    </div>
                                    <div class="c-item-text">
                                        <div class="c-item-title">Thông tin cá nhân</div>
                                        <div class="c-item-desc">Quản lý tài khoản của bạn</div>
                                    </div>
                                </a>
                                <a asp-controller="Customer" asp-action="ChangePassword" class="c-dropdown-item">
                                    <div class="c-item-icon-wrap primary">
                                        <span class="material-symbols-outlined c-item-icon">lock_reset</span>
                                    </div>
                                    <div class="c-item-text">
                                        <div class="c-item-title">Đổi mật khẩu</div>
                                        <div class="c-item-desc">Bảo mật tài khoản</div>
                                    </div>
                                </a>
                                <a asp-controller="Customer" asp-action="ProductReviews" class="c-dropdown-item border-bt">
                                    <div class="c-item-icon-wrap primary">
                                        <span class="material-symbols-outlined c-item-icon" style="font-Variation-Settings:'FILL' 1;">star</span>
                                    </div>
                                    <div class="c-item-text">
                                        <div class="c-item-title">Đánh giá</div>
                                        <div class="c-item-desc">Nhận xét của bạn</div>
                                    </div>
                                </a>
                                <a asp-controller="Home" asp-action="Response" class="c-dropdown-item">
                                    <div class="c-item-icon-wrap primary">
                                        <span class="material-symbols-outlined c-item-icon">support_agent</span>
                                    </div>
                                    <div class="c-item-text">
                                        <div class="c-item-title">Hồi đáp vấn đề</div>
                                        <div class="c-item-desc">Liên hệ hỗ trợ</div>
                                    </div>
                                </a>
                                <a asp-controller="Account" asp-action="Logout" class="c-dropdown-item logout-item">
                                    <div class="c-item-icon-wrap danger-bg">
                                        <span class="material-symbols-outlined c-item-icon" style="color:#782a2a; transform: scaleX(-1);">logout</span>
                                    </div>
                                    <div class="c-item-text" style="display:flex; align-items:center;">
                                        <div class="c-item-title" style="color:#782a2a; font-size: 1.1rem; margin:0;">Đăng xuất</div>
                                    </div>
                                </a>
                            </div>
                        </div>

                        <script>
                            function toggleCustomerDropdown(e) {
                                if(e) e.stopPropagation();
                                document.getElementById('customerDropdownMenu').classList.toggle('show');
                            }
                            // Close dropdown when clicking outside
                            window.addEventListener('click', function(e) {
                                var menu = document.getElementById('customerDropdownMenu');
                                var wrapper = document.getElementById('customerDropdownWrapper');
                                if (menu && menu.classList.contains('show') && !wrapper.contains(e.target)) {
                                    menu.classList.remove('show');
                                }
                            });
                            // Override the cart update function to also update the dropdown
                            document.addEventListener('DOMContentLoaded', function() {
                                var originalUpdateCartBadge = window.updateCartBadge;
                                if(originalUpdateCartBadge) {
                                    window.updateCartBadge = function(count) {
                                        originalUpdateCartBadge(count);
                                        var ddCount = document.getElementById('dropdown-cart-count');
                                        if(ddCount) ddCount.textContent = count;
                                    }
                                }
                            });
                        </script>

                        <!-- Cart (vẫn giữ nút riêng nhưng có the ẩn đi nếu muốn, giữ lại cho đúng logic cũ) -->
                        <a href="javascript:void(0)" onclick="window.PizzaCart.openCartDrawer()" class="btn-cart" aria-label="Giỏ hàng">
                            <span class="material-symbols-outlined">shopping_cart</span>
                            <span class="cart-badge" id="cart-count">0</span>
                        </a>
                    }
                    @if (_role != "Customer")
                    {
                        <a asp-controller="Account" asp-action="Logout" class="btn-icon" title="Đăng xuất">
                            <span class="material-symbols-outlined">logout</span>
                        </a>
                    }
                }
                else
                {
                    <!-- Chưa đăng nhập -->
                    <a asp-controller="Account" asp-action="Login" class="btn-profile">
                        <span class="material-symbols-outlined">login</span>
                        <span class="btn-profile-text">Đăng nhập</span>
                    </a>
                    <a asp-controller="Account" asp-action="Register" class="btn-cart" style="text-decoration:none; padding: 0.5rem 1rem; font-size:0.875rem; font-weight:700;">
                        Đăng ký
                    </a>
                }
            </div>
        </div>
    </header>

    <!-- ===================== MAIN ===================== -->
    <main class="main-content">

        <!-- ---- Hero Section ---- -->
        <section class="hero-section">
            <div class="container">
                <div class="hero-card">
                    <div class="hero-text">
                        <h1 class="hero-title">PizzaDeli</h1>
                        <p class="hero-desc">
                            Trải nghiệm hương vị pizza nướng bằng lò gỗ chính thống, giao tận tay khách hàng bằng cả trái tim.
                        </p>
                        <button class="btn-order">
                            <span class="material-symbols-outlined">rocket_launch</span>
                            Đặt ngay
                        </button>
                    </div>
                    <div class="hero-image">
                        <img src="~/images/banner.png" alt="PizzaDeli Special Pizza" />
                    </div>
                </div>
            </div>
        </section>

        <!-- ===== Sections theo danh mục ===== -->
        @if (Model != null && Model.Any())
        {
            bool isAlt = false;
            foreach (var cat in Model)
            {
                var products = cat.Products?.ToList() ?? new List<PizzaDeli.Models.Product>();
                <section class="menu-section @(isAlt ? "alt-bg" : "")">
                    <div class="container">
                        <div class="section-header">
                            <div>
                                <h2 class="section-title">@cat.Name</h2>
                                @if (!string.IsNullOrEmpty(cat.Description))
                                {
                                    <p class="section-subtitle">@cat.Description</p>
                                }
                            </div>
                        </div>

                        @{
                            var catId = "cat-" + cat.Id.ToString().Replace("-","");
                        }
                        <div class="products-grid" id="grid-@catId" data-cat-id="@catId">
                            @if (products.Any())
                            {
                                int pIdx = 0;
                                foreach (var p in products)
                                {
                                    <div class="product-card menu-paged-item" style="cursor: pointer;"
                                         data-page-index="@pIdx"
                                         data-product-id="@p.Id"
                                         data-product-name="@p.Name"
                                         data-product-price="@p.Price"
                                         data-product-image="@(p.ImageUrl ?? "")"
                                         data-product-cat="@cat.Name"
                                         data-product-desc="@p.Description"
                                         data-product-toppings='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(p.ProductToppings.Where(pt => pt.Topping != null).Select(pt => new { id = pt.ToppingId, name = pt.Topping!.Name, price = pt.Topping.Price })))'
                                         onclick="onCardItemClick(event, this)">
                                        <div class="card-img-wrapper">
                                            <img src="@(string.IsNullOrEmpty(p.ImageUrl) ? "/images/no-image.png" : p.ImageUrl)"
                                                 alt="@p.Name"
                                                 style="object-fit:cover; width: 100%; height: 100%;" />
                                            <div class="card-badge">
                                                <span class="material-symbols-outlined star-icon">star</span>
                                                <span class="rating">5.0</span>
                                            </div>
                                        </div>
                                        <div class="card-body">
                                            <div class="card-top">
                                                <h3 class="card-name">@p.Name</h3>
                                                <span class="card-price">@p.Price.ToString("N0") &#8363;</span>
                                            </div>
                                            <p class="card-desc line-clamp-2">@p.Description</p>
                                            <div class="card-actions">
                                                @if (isAddMore)
                                                {
                                                    <button type="button" class="btn-buy-now" title="Mua thêm" style="width: 100%; border-radius: 8px;"
                                                            data-product-id="@p.Id"
                                                            data-product-name="@p.Name"
                                                            data-product-price="@p.Price"
                                                            data-product-image="@(p.ImageUrl ?? "")"
                                                            data-product-cat="@cat.Name"
                                                            data-product-desc="@p.Description"
                                                            data-product-toppings='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(p.ProductToppings.Where(pt => pt.Topping != null).Select(pt => new { id = pt.ToppingId, name = pt.Topping!.Name, price = pt.Topping.Price })))'
                                                            onclick="onAddMoreClick(event, this)">
                                                        <span class="material-symbols-outlined pointer-events-none">add_circle</span>
                                                        <span class="pointer-events-none" style="margin-left: 0.5rem;">Mua thêm</span>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button type="button" class="btn-add-cart" title="Thêm vào giỏ"
                                                                data-product-id="@p.Id"
                                                                data-product-name="@p.Name"
                                                                data-product-price="@p.Price"
                                                                data-product-image="@(p.ImageUrl ?? "")"
                                                                data-product-cat="@cat.Name"
                                                                data-product-desc="@p.Description"
                                                                data-product-toppings='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(p.ProductToppings.Where(pt => pt.Topping != null).Select(pt => new { id = pt.ToppingId, name = pt.Topping!.Name, price = pt.Topping.Price })))'
                                                                onclick="onAddToCartClick(event, this)">
                                                        <span class="material-symbols-outlined pointer-events-none">add_shopping_cart</span>
                                                    </button>
                                                    <button type="button" class="btn-buy-now" title="Mua ngay"
                                                                data-product-id="@p.Id"
                                                                data-product-name="@p.Name"
                                                                data-product-price="@p.Price"
                                                                data-product-image="@(p.ImageUrl ?? "")"
                                                                data-product-cat="@cat.Name"
                                                                data-product-desc="@p.Description"
                                                                data-product-toppings='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(p.ProductToppings.Where(pt => pt.Topping != null).Select(pt => new { id = pt.ToppingId, name = pt.Topping!.Name, price = pt.Topping.Price })))'
                                                                onclick="onBuyNowClick(event, this)">
                                                        <span class="material-symbols-outlined pointer-events-none">payments</span>
                                                        <span class="pointer-events-none">Mua ngay</span>
                                                    </button>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                    pIdx++;
                                }
                            }
                            else
                            {
                                <div style="grid-column: 1/-1; padding: 3rem 0; text-align:center; color:#9ca3af;">
                                    <span class="material-symbols-outlined" style="font-size:2.5rem; opacity:0.3;">restaurant_menu</span>
                                    <p style="margin-top:.75rem; font-weight:600;">Chưa có sản phẩm trong danh mục này</p>
                                </div>
                            }
                        </div>
                        <!-- Pagination controls rendered by JS -->
                        <div class="menu-pagination" id="pager-@catId"></div>
                    </div>
                </section>
                isAlt = !isAlt;
            }
        }
        else
        {
            <section class="menu-section">
                <div class="container" style="padding: 5rem 0; text-align:center; color:#9ca3af;">
                    <span class="material-symbols-outlined" style="font-size:4rem; opacity:0.3;">restaurant_menu</span>
                    <p style="margin-top:1rem; font-size:1.2rem; font-weight:600;">Chưa có danh mục nào</p>
                </div>
            </section>
        }

    </main>

    <!-- ===================== FOOTER ===================== -->
    <footer class="site-footer" id="footer">
        <div class="container">
            <div class="footer-grid">

                <!-- Brand -->
                <div class="footer-brand">
                    <div class="footer-brand-row">
                        <span class="material-symbols-outlined">local_pizza</span>
                        <span class="footer-brand-name">PizzaDeli</span>
