@model List<PizzaDeli.Models.ContactRequest>
@{
    ViewData["Title"] = "Hồi đáp vấn đề";
    Layout = "_Layout";
}

@section Styles {
    <style>
        .response-page {
            background-color: #f8f9fa;
            min-height: calc(100vh - 80px);
            padding: 2rem 0;
            font-family: 'Inter', sans-serif;
        }

        .response-container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 1rem;
            display: grid;
            grid-template-columns: 320px 1fr;
            gap: 2rem;
            align-items: flex-start;
        }

        /* --- Cột trái: Danh sách phản hồi --- */
        .response-sidebar {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            max-height: 800px;
            overflow-y: auto;
        }
        
        .response-sidebar::-webkit-scrollbar { width: 6px; }
        .response-sidebar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 99px; }

        .rs-item {
            background: #ffffff;
            border-radius: 12px;
            padding: 1.25rem;
            box-shadow: 0 2px 6px rgba(0,0,0,0.03);
            border: 2px solid transparent;
            cursor: pointer;
            transition: all 0.2s;
        }
        .rs-item.active { border-color: #5c3e34; box-shadow: 0 4px 12px rgba(92,62,52,0.1); }
        .rs-item:hover { transform: translateY(-2px); }

        .rs-item-top {
            display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;
        }
        .rs-type { font-size: 0.75rem; font-weight: 800; color: #64748b; }
        .rs-time { font-size: 0.7rem; color: #9ca3af; font-weight: 600; }
        .rs-desc { font-size: 0.95rem; font-weight: 700; color: #1f2937; margin-bottom: 0.75rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
        
        .rs-status-badge {
            font-size: 0.65rem; padding: 0.3rem 0.6rem; border-radius: 99px;
            background: #e5e7eb; color: #4b5563; font-weight: 800; text-transform: uppercase;
        }
        .status-Waiting { background: #e0f2fe; color: #0369a1; }
        .status-Processing { background: #ffedd5; color: #c2410c; }

        /* --- Cột phải: Khung Chat --- */
        .response-detail {
            background: #ffffff;
            border-radius: 24px;
            border: 1px solid #f3f4f6;
            box-shadow: 0 4px 20px rgba(0,0,0,0.04);
            display: flex;
            flex-direction: column;
            height: 700px;
        }

        .chat-history {
            flex: 1; padding: 2.5rem; overflow-y: auto; display: flex; flex-direction: column; gap: 1.5rem;
        }

        .msg-block { display: flex; flex-direction: column; gap: 0.25rem; max-width: 80%; }
        .msg-block.customer { align-self: flex-end; align-items: flex-end; }
        .msg-block.admin { align-self: flex-start; align-items: flex-start; }

        .msg-bubble {
            padding: 1rem 1.25rem;
            border-radius: 16px;
            font-size: 0.95rem; line-height: 1.5;
        }
        .msg-block.customer .msg-bubble {
            background: #e0ece4; color: #173620; /* Dark green text on light green */
            border-bottom-right-radius: 4px;
        }
        .msg-block.admin .msg-bubble {
            background: #f1f5f9; color: #334155;
            border-bottom-left-radius: 4px; border: 1px solid #e2e8f0;
        }

        .msg-meta { font-size: 0.75rem; color: #9ca3af; font-weight: 600; padding: 0 0.5rem; }

        .rd-footer {
            padding: 1.25rem 2rem;
            border-top: 1px solid #f3f4f6;
            display: flex; gap: 1rem;
        }
        .rd-footer input {
            flex: 1; padding: 0.75rem 1.5rem; border-radius: 99px;
            border: 1px solid #e2e8f0; background: #f8fafc; font-size: 0.95rem; outline: none;
        }
        .btn-primary-rs {
            background: #5c3e34; color: #ffffff; font-weight: 700; border: none;
            padding: 0 1.5rem; border-radius: 99px; cursor: pointer; transition: 0.2s;
            display: flex; align-items: center; justify-content: center; gap: 0.5rem;
        }
        .btn-primary-rs:hover { background: #4a2c22; transform: translateY(-1px); }
    </style>
}

<div class="response-page">
    <div style="max-width: 1100px; margin: 0 auto; padding: 0 1rem 1.5rem 1rem;">
        <a href="/" style="display:inline-flex; align-items:center; gap:0.5rem; color:#64748b; font-weight:700; text-decoration:none;">
            <span class="material-symbols-outlined">arrow_back</span>
            Trang chủ
        </a>
    </div>
    <div class="response-container">
        
        <!-- Sidebar -->
        <div class="response-sidebar">
            <h2 style="font-size: 1.4rem; font-weight: 800; color: #1e293b; margin-bottom:0.5rem;">Hỗ trợ của tôi</h2>
            
            @if(Model.Count == 0) {
                <div style="color: #64748b; font-size: 0.9rem; margin-top: 1rem;">Chưa có yêu cầu hỗ trợ nào.</div>
            }

            @foreach(var ticket in Model) {
                <div class="rs-item" onclick="openTicket(this)" data-id="@ticket.Id" data-code="@ticket.OrderCode" data-msg="@ticket.Message" data-time="@ticket.CreatedAt.ToString("dd/MM/yyyy HH:mm")">
                    <div class="rs-item-top">
                        <span class="rs-type">@ticket.OrderCode</span>
                        <span class="rs-time">@ticket.CreatedAt.ToString("dd/MM")</span>
                    </div>
                    <div class="rs-desc">@ticket.Message</div>
                    <span class="rs-status-badge status-@ticket.Status">@ticket.Status</span>
                </div>
            }
        </div>

        <!-- Detail Panel -->
        <div class="response-detail" id="response-detail" style="display: none;">
            <div style="padding: 1.5rem; border-bottom: 1px solid #f3f4f6; display:flex; align-items:center; gap: 1rem;">
                <div style="width: 44px; height: 44px; border-radius: 50%; background: #f1f5f9; display:flex; align-items:center; justify-content:center; color: #5c3e34;">
                    <span class="material-symbols-outlined" style="font-size: 1.5rem;">support_agent</span>
                </div>
                <div>
                    <div style="font-weight: 800; color: #1e293b; font-size: 1.1rem;">Nhân viên CSKH</div>
                    <div style="font-size: 0.8rem; color: #22c55e; font-weight: 700; display:flex; align-items:center; gap:0.25rem;">
                        <span style="display:inline-block; width:6px; height:6px; background:#22c55e; border-radius:50%;"></span>
                        Đang hoạt động
                    </div>
                </div>
            </div>

            <div class="chat-history" id="chat-history-container">
                <!-- Data here -->
            </div>
            
            <!-- Footer form -->
            <div class="rd-footer">
                <input type="text" id="chatInput" placeholder="Nhập tin nhắn để thảo luận..." />
                <button class="btn-primary-rs" id="btnSend">
                    Gửi <span class="material-symbols-outlined" style="font-size:1.1rem;">send</span>
                </button>
            </div>
        </div>

        <div id="blank-detail" style="display: flex; align-items:center; justify-content:center; background:#fff; border-radius: 24px; border: 2px dashed #e2e8f0; height: 700px;">
            <div style="text-align: center; color: #94a3b8;">
                <span class="material-symbols-outlined" style="font-size: 4rem; margin-bottom:1rem; opacity: 0.3;">question_answer</span>
                <div style="font-weight: 700; font-size: 1.1rem;">Nhấn vào một yêu cầu để xem tin nhắn từ Nhân viên</div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        let currentTicketId = null;
        let originalMsg = "";
        let originalTime = "";
        let chatInterval = null;
        let lastMsgCount = 0;

        function openTicket(el) {
            document.querySelectorAll('.rs-item').forEach(e => e.classList.remove('active'));
            el.classList.add('active');

            document.getElementById('blank-detail').style.display = 'none';
            document.getElementById('response-detail').style.display = 'flex';

            currentTicketId = el.getAttribute('data-id');
            originalMsg = el.getAttribute('data-msg');
            originalTime = el.getAttribute('data-time');

            // Render original message as Customer's first message
            const container = document.getElementById('chat-history-container');
            container.innerHTML = `
                <div class="msg-block customer">
                    <div class="msg-meta">Bạn (Lúc tạo form)</div>
                    <div class="msg-bubble">${originalMsg}</div>
                </div>
            `;

            lastMsgCount = 0;
            if(chatInterval) clearInterval(chatInterval);
            fetchMessages();
            chatInterval = setInterval(fetchMessages, 2000);
        }

        function fetchMessages() {
            if(!currentTicketId) return;
            fetch('/api/contactchat/' + currentTicketId)
                .then(r => r.json())
                .then(msgs => {
                    if (msgs.length > lastMsgCount) {
                        const container = document.getElementById('chat-history-container');
                        for(let i = lastMsgCount; i < msgs.length; i++) {
                            let m = msgs[i];
                            let isCustomer = m.sender === 'Customer';
                            container.insertAdjacentHTML('beforeend', `
                                <div class="msg-block ${isCustomer ? 'customer' : 'admin'}">
                                    <div class="msg-meta">${isCustomer ? 'Bạn' : 'Nhân viên KSCR'} &bull; ${m.time}</div>
                                    <div class="msg-bubble">${m.content}</div>
                                </div>
                            `);
                        }
                        lastMsgCount = msgs.length;
                        container.scrollTop = container.scrollHeight;
                    }
                });
        }

        document.getElementById('btnSend').addEventListener('click', () => {
            const input = document.getElementById('chatInput');
            const txt = input.value.trim();
            if(!txt || !currentTicketId) return;

            const fd = new FormData();
            fd.append("ticketId", currentTicketId);
            fd.append("sender", "Customer");
            fd.append("content", txt);

            fetch('/api/contactchat/send', { method: 'POST', body: fd })
            .then(r => r.json())
            .then(res => {
                if(res.success) {
                    input.value = '';
                    fetchMessages();
                }
            });
        });

        document.getElementById('chatInput').addEventListener('keypress', (e) => {
            if(e.key === 'Enter') document.getElementById('btnSend').click();
        });
    </script>
}
