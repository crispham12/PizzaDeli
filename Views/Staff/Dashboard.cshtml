@{
    ViewData["Title"] = "Nhân viên Dashboard";
}

<div class="dash-page">
    <aside class="dash-sidebar">
        <div class="dash-logo">
            <span class="material-symbols-outlined">local_pizza</span>
            <span>PizzaDeli</span>
        </div>
        <div class="dash-role-badge staff">Nhân viên</div>
        <nav class="dash-nav">
            <a asp-controller="Staff" asp-action="Dashboard" class="dash-nav-item active">
                <span class="material-symbols-outlined">dashboard</span> Tổng quan
            </a>
            <a asp-controller="Staff" asp-action="Orders" class="dash-nav-item">
                <span class="material-symbols-outlined">receipt_long</span> Quản lý đơn hàng
            </a>
            <a asp-controller="Staff" asp-action="Deliveries" class="dash-nav-item">
                <span class="material-symbols-outlined">delivery_dining</span> Giao hàng
            </a>
            <a asp-controller="Staff" asp-action="Customers" class="dash-nav-item">
                <span class="material-symbols-outlined">support_agent</span> Hỗ trợ KH
            </a>
            <a asp-controller="Staff" asp-action="Comments" class="dash-nav-item">
                <span class="material-symbols-outlined">comment</span> Bình luận
            </a>
        </nav>
        <div class="dash-sidebar-footer">
            <span class="dash-username">@Context.Session.GetString("USER_NAME")</span>
            <a asp-controller="Account" asp-action="Logout" class="dash-logout">
                <span class="material-symbols-outlined">logout</span>
            </a>
        </div>
    </aside>

    <main class="dash-main">
        <header class="dash-header">
            <h1>Bảng điều khiển nhân viên</h1>
            <span class="dash-date" id="dash-date"></span>
        </header>

        <div class="stat-grid">
            <div class="stat-card">
                <div class="stat-icon orders"><span class="material-symbols-outlined">pending_actions</span></div>
                <div class="stat-info">
                    <span class="stat-label">Đơn chờ xử lý</span>
                    <span class="stat-value">--</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon revenue"><span class="material-symbols-outlined">delivery_dining</span></div>
                <div class="stat-info">
                    <span class="stat-label">Đang giao</span>
                    <span class="stat-value">--</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon products"><span class="material-symbols-outlined">task_alt</span></div>
                <div class="stat-info">
                    <span class="stat-label">Đã hoàn thành hôm nay</span>
                    <span class="stat-value">--</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon customers"><span class="material-symbols-outlined">forum</span></div>
                <div class="stat-info">
                    <span class="stat-label">Bình luận chờ duyệt</span>
                    <span class="stat-value">--</span>
                </div>
            </div>
        </div>

        <section class="dash-section">
            <h2 class="dash-section-title">Chức năng nhân viên</h2>
            <div class="usecase-grid">
                <div class="usecase-card">
                    <span class="material-symbols-outlined usecase-icon">receipt_long</span>
                    <h3>Quản lý đơn hàng</h3>
                    <ul>
                        <li>Xem danh sách đơn hàng</li>
                        <li>Xem chi tiết đơn</li>
                        <li>Cập nhật trạng thái đơn</li>
                    </ul>
                </div>
                <div class="usecase-card">
                    <span class="material-symbols-outlined usecase-icon">delivery_dining</span>
                    <h3>Xử lý giao hàng</h3>
                    <ul>
                        <li>Theo dõi lộ trình giao hàng</li>
                        <li>Cập nhật trạng thái giao hàng</li>
                    </ul>
                </div>
                <div class="usecase-card">
                    <span class="material-symbols-outlined usecase-icon">support_agent</span>
                    <h3>Hỗ trợ khách hàng</h3>
                    <ul>
                        <li>Xem thông tin khách hàng</li>
                        <li>Phản hồi yêu cầu hỗ trợ</li>
                    </ul>
                </div>
                <div class="usecase-card">
                    <span class="material-symbols-outlined usecase-icon">comment</span>
                    <h3>Quản lý bình luận</h3>
                    <ul>
                        <li>Xem danh sách bình luận</li>
                        <li>Ẩn / xóa bình luận vi phạm</li>
                        <li>Trả lời phản hồi khách hàng</li>
                    </ul>
                </div>
            </div>
        </section>
    </main>
</div>

<script>
document.getElementById('dash-date').textContent = new Date().toLocaleDateString('vi-VN', {
    weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
});
</script>
